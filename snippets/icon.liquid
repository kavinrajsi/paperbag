{% doc %}
  Renders an inline SVG icon.

  @param {string} icon - The icon name to render
  @param {string} [size] - Icon size in pixels (default: 24)
  @param {string} [class] - Additional CSS class

  @example
  {% render 'icon', icon: 'cart' %}
  {% render 'icon', icon: 'search', size: 20 %}
{% enddoc %}

{%- liquid
  unless size
    assign size = 24
  endunless
-%}

<svg
  class="icon icon-{{ icon }}{% if class %} {{ class }}{% endif %}"
  width="{{ size }}"
  height="{{ size }}"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
>
  {%- case icon -%}
    {%- when 'search' -%}
      <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
    {%- when 'cart' -%}
      <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 01-8 0"/>
    {%- when 'menu' -%}
      <path d="M3 12h18M3 6h18M3 18h18"/>
    {%- when 'close' -%}
      <path d="M18 6L6 18M6 6l12 12"/>
    {%- when 'chevron-down' -%}
      <path d="M6 9l6 6 6-6"/>
    {%- when 'chevron-left' -%}
      <path d="M15 18l-6-6 6-6"/>
    {%- when 'chevron-right' -%}
      <path d="M9 18l6-6-6-6"/>
    {%- when 'chevron-up' -%}
      <path d="M18 15l-6-6-6 6"/>
    {%- when 'arrow-right' -%}
      <path d="M5 12h14M12 5l7 7-7 7"/>
    {%- when 'plus' -%}
      <path d="M12 5v14M5 12h14"/>
    {%- when 'minus' -%}
      <path d="M5 12h14"/>
    {%- when 'check' -%}
      <path d="M20 6L9 17l-5-5"/>
    {%- when 'person' -%}
      <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
    {%- when 'heart' -%}
      <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
    {%- when 'share' -%}
      <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="M8.59 13.51l6.83 3.98M15.41 6.51l-6.82 3.98"/>
    {%- when 'facebook' -%}
      <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
    {%- when 'instagram' -%}
      <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><path d="M17.5 6.5h.01"/>
    {%- when 'twitter' -%}
      <path d="M4 4l11.733 16h4.267l-11.733-16zM4 20l6.768-6.768M13.232 10.768L20 4"/>
    {%- when 'pinterest' -%}
      <path d="M12 2C6.477 2 2 6.477 2 12c0 4.237 2.636 7.855 6.356 9.312-.088-.791-.167-2.005.035-2.868.181-.781 1.168-4.947 1.168-4.947s-.299-.597-.299-1.479c0-1.385.803-2.42 1.803-2.42.85 0 1.261.638 1.261 1.403 0 .854-.544 2.132-.825 3.317-.234.991.497 1.799 1.474 1.799 1.77 0 3.13-1.867 3.13-4.557 0-2.382-1.713-4.048-4.158-4.048-2.833 0-4.496 2.124-4.496 4.322 0 .856.33 1.773.741 2.272a.3.3 0 01.069.286c-.076.312-.243 .991-.276 1.129-.043.183-.145.222-.334.134-1.249-.581-2.03-2.407-2.03-3.874 0-3.154 2.292-6.052 6.608-6.052 3.469 0 6.165 2.473 6.165 5.776 0 3.447-2.173 6.22-5.19 6.22-1.013 0-1.966-.527-2.292-1.148l-.623 2.378c-.226.869-.835 1.958-1.244 2.621.937.29 1.931.446 2.962.446 5.523 0 10-4.477 10-10S17.523 2 12 2z"/>
    {%- when 'tiktok' -%}
      <path d="M9 12a4 4 0 104 4V4a5 5 0 005 5"/>
    {%- when 'youtube' -%}
      <path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.43z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="currentColor" stroke="none"/>
    {%- when 'zoom' -%}
      <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35M11 8v6M8 11h6"/>
    {%- when 'star' -%}
      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
    {%- when 'star-filled' -%}
      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" fill="currentColor"/>
  {%- endcase -%}
</svg>
