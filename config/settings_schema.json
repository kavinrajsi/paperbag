  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "t:settings_schema.cart.settings.cart_type.label",
        "options": [
          {
            "value": "drawer",
            "label": "t:settings_schema.cart.settings.cart_type.options.drawer"
          },
          {
            "value": "page",
            "label": "t:settings_schema.cart.settings.cart_type.options.page"
          }
        ],
        "default": "drawer"
      },
      {
        "type": "checkbox",
        "id": "enable_cart_notes",
        "label": "t:settings_schema.cart.settings.enable_cart_notes.label",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_upsells",
        "label": "t:settings_schema.cart.settings.enable_upsells.label",
        "default": true
      }
    ]
  },
  {
    "name": "Product",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_size_guide",
        "label": "t:settings_schema.product.settings.enable_size_guide.label",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_recently_viewed",
        "label": "t:settings_schema.product.settings.enable_recently_viewed.label",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_sticky_cart",
        "label": "t:settings_schema.product.settings.enable_sticky_cart.label",
        "default": true
      }
    ]
  },
  {
    "name": "Search",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_predictive_search",
        "label": "t:settings_schema.search.settings.enable_predictive_search.label",
        "default": true
