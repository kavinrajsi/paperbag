  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "heading_font",
        "label": "t:settings_schema.typography.settings.heading_font.label",
        "default": "assistant_n4"
      },
      {
        "type": "font_picker",
        "id": "body_font",
        "label": "t:settings_schema.typography.settings.body_font.label",
        "default": "assistant_n4"
      },
      {
        "type": "range",
        "id": "base_font_size",
        "label": "t:settings_schema.typography.settings.base_font_size.label",
        "min": 14,
        "max": 20,
        "step": 1,
        "default": 16,
        "unit": "px"
      }
    ]
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "t:settings_schema.logo.settings.logo.label"
      },
      {
        "type": "range",
        "id": "logo_width",
        "label": "t:settings_schema.logo.settings.logo_width.label",
        "min": 50,
        "max": 200,
        "step": 10,
        "default": 120,
        "unit": "px"
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "t:settings_schema.logo.settings.favicon.label"
      }
    ]
  },
  {
    "name": "Social media",
