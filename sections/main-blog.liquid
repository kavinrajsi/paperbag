{%- paginate blog.articles by section.settings.articles_per_page -%}
<div class="blog-page">
  <div class="container">
    <h1 class="blog-page__title">{{ blog.title }}</h1>

    <div class="blog-page__grid">
      {%- for article in blog.articles -%}
        <article class="blog-card">
          {%- if article.image != blank -%}
            <a href="{{ article.url }}" class="blog-card__image">
              {%- render 'image', image: article.image, widths: '360,535,750', sizes: '(min-width: 990px) 33vw, 50vw' -%}
            </a>
          {%- endif -%}
          <div class="blog-card__content">
            {%- if section.settings.show_date -%}
              <time class="blog-card__date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                {{ article.published_at | date: '%B %d, %Y' }}
              </time>
            {%- endif -%}
            <h2 class="blog-card__title"><a href="{{ article.url }}">{{ article.title }}</a></h2>
            {%- if article.excerpt_or_content != blank -%}
              <p class="blog-card__excerpt">{{ article.excerpt_or_content | strip_html | truncatewords: 20 }}</p>
            {%- endif -%}
            <a href="{{ article.url }}" class="blog-card__link">{{ 'blog.read_more' | t | default: 'Read More' }}</a>
          </div>
        </article>
      {%- endfor -%}
    </div>

    {%- render 'pagination', paginate: paginate -%}
  </div>
</div>
{%- endpaginate -%}

{% stylesheet %}
  .blog-page { padding: 32px 0 64px; }
  .blog-page__title { font-family: 'Outfit', sans-serif; font-size: 32px; color: #313D65; font-weight: normal; text-align: center; margin: 0 0 40px; }
  .blog-page__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .blog-card__image { display: block; aspect-ratio: 4/3; overflow: hidden; background: #f5f5f5; }
  .blog-card__image img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s ease; }
  .blog-card:hover .blog-card__image img { transform: scale(1.03); }
  .blog-card__content { padding: 16px 0; }
  .blog-card__date { font-family: 'Outfit', sans-serif; font-size: 12px; color: #ADADAD; text-transform: uppercase; letter-spacing: 0.05em; }
  .blog-card__title { font-family: 'Outfit', sans-serif; font-size: 20px; color: #313D65; font-weight: normal; margin: 8px 0; }
  .blog-card__title a { color: inherit; text-decoration: none; }
  .blog-card__title a:hover { text-decoration: underline; }
  .blog-card__excerpt { font-family: 'Outfit', sans-serif; font-size: 16px; color: #353535; line-height: 1.8; margin: 0 0 12px; }
  .blog-card__link { font-family: 'Outfit', sans-serif; font-size: 14px; font-weight: 600; color: #313D65; text-decoration: none; text-transform: capitalize; }
  .blog-card__link:hover { text-decoration: underline; }
  @media (min-width: 750px) and (max-width: 989px) { .blog-page__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 749px) { .blog-page__title { font-size: 22px; margin-bottom: 24px; } .blog-page__grid { grid-template-columns: 1fr; gap: 32px; } .blog-card__title { font-size: 18px; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Blog page",
  "settings": [
    { "type": "range", "id": "articles_per_page", "label": "Articles per page", "min": 3, "max": 24, "step": 3, "default": 9 },
    { "type": "select", "id": "columns", "label": "Columns", "options": [{"value":"2","label":"2"},{"value":"3","label":"3"}], "default": "3" },
    { "type": "checkbox", "id": "show_date", "label": "Show date", "default": true },
    { "type": "checkbox", "id": "show_author", "label": "Show author", "default": true }
  ]
}
{% endschema %}
