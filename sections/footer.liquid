{%- liquid
  if section.settings.color_scheme == 'dark'
    assign footer_bg = 'var(--color-primary)'
    assign footer_color = '#FFFFFF'
  else
    assign footer_bg = '#FFFFFF'
    assign footer_color = 'var(--color-primary)'
  endif
-%}

<footer class="footer footer--{{ section.settings.color_scheme }}" style="background-color: {{ footer_bg }}; color: {{ footer_color }}">
  <div class="container">
    <div class="footer__grid">
      {%- for block in section.blocks -%}
        <div class="footer__column" {{ block.shopify_attributes }}>
          {%- case block.type -%}
            {%- when 'menu' -%}
              {%- if block.settings.menu != blank -%}
                {%- assign menu = linklists[block.settings.menu] -%}
                <h4 class="footer__heading">{{ menu.title }}</h4>
                <ul class="footer__links">
                  {%- for link in menu.links -%}
                    <li>
                      <a href="{{ link.url }}">{{ link.title }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}

            {%- when 'text' -%}
              {%- if block.settings.heading != blank -%}
                <h4 class="footer__heading">{{ block.settings.heading }}</h4>
              {%- endif -%}
              {%- if block.settings.content != blank -%}
                <div class="footer__text">{{ block.settings.content }}</div>
              {%- endif -%}

            {%- when 'newsletter' -%}
              {%- if block.settings.heading != blank -%}
                <h4 class="footer__heading">{{ block.settings.heading }}</h4>
              {%- endif -%}
              {%- if block.settings.subtext != blank -%}
                <div class="footer__newsletter-subtext">{{ block.settings.subtext }}</div>
              {%- endif -%}
              {%- form 'customer', class: 'footer__newsletter-form' -%}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <div class="footer__newsletter-input-wrapper">
                  <input
                    type="email"
                    name="contact[email]"
                    class="footer__newsletter-input"
                    placeholder="Your email"
                    required
                    aria-label="Email address"
                    autocomplete="email"
                  >
                  <button type="submit" class="footer__newsletter-button" aria-label="Subscribe">
                    {%- render 'icon', icon: 'arrow-right', size: 20 -%}
                  </button>
                </div>
              {%- endform -%}
          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>

    <div class="footer__bottom">
      <p class="footer__copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</p>
      <div class="footer__payment-icons">
        {{ shop | payment_type_svg_tag }}
      </div>
      {%- render 'social-icons' -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        {
          "value": "light",
          "label": "Light"
        },
        {
          "value": "dark",
          "label": "Dark"
        }
      ],
      "default": "dark"
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu",
      "settings": [
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "main-menu"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Subscribe"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "label": "Subtext"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        {
          "type": "menu",
          "settings": {
            "menu": "main-menu"
          }
        },
        {
          "type": "text"
        }
      ]
    }
  ]
}
{% endschema %}
