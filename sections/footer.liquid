<footer class="site-footer">
  <div class="site-footer__inner">
    {%- comment -%} Left: Logo + social + copyright {%- endcomment -%}
    <div class="site-footer__brand">
      <div class="site-footer__logo">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 400 }}"
            alt="{{ shop.name | escape }}"
            loading="lazy"
            class="site-footer__logo-img"
          >
        {%- else -%}
          <img
            src="{{ 'logo.png' | asset_url }}"
            alt="{{ shop.name | escape }}"
            loading="lazy"
            class="site-footer__logo-img"
          >
        {%- endif -%}
        {%- if section.settings.tagline != blank -%}
          <p class="site-footer__tagline">{{ section.settings.tagline }}</p>
        {%- endif -%}
      </div>

      <div class="site-footer__social">
        {%- render 'social-icons' -%}
      </div>

    </div>

    {%- comment -%} Right: Link columns {%- endcomment -%}
    <div class="site-footer__nav">
      <div class="site-footer__column">
        <h4 class="site-footer__heading">Paperbag</h4>
        <ul class="site-footer__links">
          <li><a href="/collections/all">Shop</a></li>
          <li><a href="/collections">Collections</a></li>
          <li><a href="/pages/about">About</a></li>
        </ul>
      </div>
      <div class="site-footer__column">
        <h4 class="site-footer__heading">Help & Support</h4>
        <ul class="site-footer__links">
          <li><a href="/policies/shipping-policy">Orders & Shipping</a></li>
          <li><a href="/policies/refund-policy">Returns & Refunds</a></li>
          <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
          <li><a href="/policies/terms-of-service">Terms & Conditions</a></li>
          <li><a href="/pages/contact">Contact</a></li>
        </ul>
      </div>
    </div>
  </div>
</footer>

<div class="popular-searches">
  <div class="container">
    <h4 class="popular-searches__heading">Popular Searches</h4>
    <p class="popular-searches__links">
      <a href="/collections/tops">Tops</a>
      <a href="/collections/bottoms">Bottoms</a>
      <a href="/collections/co-ords">Co-ords</a>
      <a href="/collections/dress">Dress</a>
      <a href="/search?q=wrap+top">Wrap Top</a>
      <a href="/search?q=shirts">Shirts</a>
      <a href="/search?q=skirts">Skirts</a>
      <a href="/search?q=trousers">Trousers</a>
      <a href="/search?q=palazzo">Palazzo</a>
      <a href="/search?q=casual+wear">Casual Wear</a>
      <a href="/search?q=office+wear">Office Wear</a>
      <a href="/search?q=cotton">Cotton</a>
      <a href="/search?q=linen">Linen</a>
      <a href="/search?q=handmade">Handmade</a>
      <a href="/search?q=summer+collection">Summer Collection</a>
      <a href="/search?q=new+arrivals">New Arrivals</a>
      <a href="/search?q=best+sellers">Best Sellers</a>
    </p>
  </div>
</div>

<div class="site-copyright">
  <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All Rights Reserved.</p>
</div>

{% stylesheet %}
  /* ── Popular Searches ── */
  .popular-searches {
    padding: 32px 0;
    background-color: #8FA1B7;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
  }

  .popular-searches__heading {
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 16px;
    padding-bottom: 8px;
    border-bottom: 2px solid rgba(255, 255, 255, 0.4);
    display: inline-block;
  }

  .popular-searches__links {
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.85);
    line-height: 2;
    margin: 0;
  }

  .popular-searches__links a {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
  }

  .popular-searches__links a:hover {
    color: #fff;
  }

  .popular-searches__links a + a::before {
    content: '  |  ';
    color: rgba(255, 255, 255, 0.4);
  }

  .site-copyright {
    background-color: #8FA1B7;
    text-align: center;
    padding: 16px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
  }

  .site-copyright p {
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: #fff;
    margin: 0;
  }
  .site-footer {
    background-color: #8FA1B7;
    color: #fff;
    padding: 64px 0 32px;
  }

  .site-footer a {
    color: #fff;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .site-footer a:hover {
    opacity: 0.75;
  }

  .site-footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 64px;
  }

  /* ── Brand column (left) ── */
  .site-footer__brand {
    display: flex;
    flex-direction: column;
    gap: 0;
    min-width: 300px;
  }

  .site-footer__logo {
    margin-bottom: 48px;
  }

  .site-footer__logo-img {
    max-width: 391px;
    height: auto;
    display: block;
  }

  .site-footer__logo-text {
    font-family: 'Outfit', sans-serif;
    font-size: 48px;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.02em;
  }

  .site-footer__tagline {
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #FAF8F3;
    margin: 8px 0 0;
    opacity: 0.85;
  }

  .site-footer__social {
    margin-bottom: 24px;
  }

  .site-footer__social .social-icons {
    gap: 16px;
  }

  .site-footer__social .social-icons__link {
    opacity: 1;
    color: #fff;
  }

  .site-footer__copyright {
    font-family: 'Outfit', sans-serif;
    font-size: 12px;
    font-weight: 400;
    color: #FAF8F3;
    line-height: 1.8;
    margin: 0;
    text-transform: capitalize;
  }

  /* ── Nav columns (right) ── */
  .site-footer__nav {
    display: flex;
    gap: 24px;
    flex-shrink: 0;
  }

  .site-footer__column {
    min-width: 184px;
  }

  .site-footer__heading {
    font-family: 'Outfit', sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: #fff;
    text-transform: capitalize;
    margin: 0 0 24px;
    line-height: 1.4;
  }

  .site-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .site-footer__links a {
    font-family: 'Outfit', sans-serif;
    font-size: 18px;
    font-weight: 400;
    line-height: 1.8;
    text-transform: capitalize;
    white-space: nowrap;
  }

  /* ── Tablet ── */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .site-footer__inner {
      flex-direction: column;
      gap: 40px;
    }

    .site-footer__nav {
      width: 100%;
      justify-content: flex-start;
    }

    .site-footer__brand {
      min-width: auto;
    }
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    .site-footer {
      padding: 40px 0 24px;
    }

    .site-footer__inner {
      flex-direction: column;
      gap: 32px;
      padding: 0 20px;
    }

    .site-footer__brand {
      min-width: auto;
    }

    .site-footer__logo {
      margin-bottom: 32px;
    }

    .site-footer__logo-img {
      max-width: 240px;
    }

    .site-footer__logo-text {
      font-size: 32px;
    }

    .site-footer__nav {
      flex-direction: column;
      gap: 32px;
      width: 100%;
    }

    .site-footer__column {
      min-width: auto;
    }

    .site-footer__heading {
      font-size: 18px;
      margin-bottom: 16px;
    }

    .site-footer__links a {
      font-size: 16px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer logo"
    },
    {
      "type": "text",
      "id": "tagline",
      "default": "Effortless. Elevated.",
      "label": "Tagline"
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading override"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        {
          "type": "menu",
          "settings": {
            "heading": "Paperbag",
            "menu": "footer"
          }
        },
        {
          "type": "menu",
          "settings": {
            "heading": "Help & Support",
            "menu": "footer"
          }
        }
      ]
    }
  ]
}
{% endschema %}
