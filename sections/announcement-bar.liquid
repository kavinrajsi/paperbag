<div class="announcement-bar" data-announcement-bar style="background-color: {{ section.settings.color_background }}; color: {{ section.settings.color_text }}">
  {%- if section.settings.link != blank -%}
    <a href="{{ section.settings.link }}" class="announcement-bar__link">
      <span class="announcement-bar__text">{{ section.settings.text }}</span>
    </a>
  {%- else -%}
    <span class="announcement-bar__text">{{ section.settings.text }}</span>
  {%- endif -%}
</div>

{% stylesheet %}
  .announcement-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 30px;
    font-family: var(--font-family);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.8px;
    text-align: center;
    overflow: hidden;
    position: sticky;
    top: 0;
    z-index: 101;
    transition: transform 0.3s ease, margin-bottom 0.3s ease;
  }

  .announcement-bar--hidden {
    transform: translateY(-100%);
    margin-bottom: -30px;
  }

  .announcement-bar__link {
    color: inherit;
    text-decoration: none;
  }

  .announcement-bar__link:hover {
    text-decoration: underline;
  }

  .announcement-bar__text {
    line-height: 1;
    white-space: nowrap;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Enjoy Free Shipping On All Orders"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "color",
      "id": "color_background",
      "label": "Background color",
      "default": "#8FA1B7"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Text color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "Announcement bar"
    }
  ]
}
{% endschema %}
