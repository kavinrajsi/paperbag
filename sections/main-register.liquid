<div class="auth-page">
  <div class="container">
    <div class="auth-page__card">
      <h1 class="auth-page__title">{{ 'customer.register.title' | t }}</h1>

      {% form 'create_customer' %}
        {%- if form.errors -%}
          <div class="auth-page__error">{{ form.errors | default_errors }}</div>
        {%- endif -%}
        <div class="auth-page__row">
          <div class="auth-page__field">
            <label for="FirstName" class="auth-page__label">{{ 'customer.register.first_name' | t }}</label>
            <input type="text" id="FirstName" name="customer[first_name]" required class="auth-page__input">
          </div>
          <div class="auth-page__field">
            <label for="LastName" class="auth-page__label">{{ 'customer.register.last_name' | t }}</label>
            <input type="text" id="LastName" name="customer[last_name]" required class="auth-page__input">
          </div>
        </div>
        <div class="auth-page__field">
          <label for="Email" class="auth-page__label">{{ 'customer.register.email' | t }}</label>
          <input type="email" id="Email" name="customer[email]" required class="auth-page__input">
        </div>
        <div class="auth-page__field">
          <label for="Password" class="auth-page__label">{{ 'customer.register.password' | t }}</label>
          <input type="password" id="Password" name="customer[password]" required class="auth-page__input">
        </div>
        <button type="submit" class="auth-page__btn">{{ 'customer.register.submit' | t }}</button>
      {% endform %}

      <p class="auth-page__link-row" style="margin-top: 16px;">
        {{ 'customer.register.already_have_account' | t }}
        <a href="{{ routes.account_login_url }}" class="auth-page__link">{{ 'customer.login.sign_in' | t }}</a>
      </p>
    </div>
  </div>
</div>

{% schema %}
{ "name": "Customer register", "settings": [] }
{% endschema %}
