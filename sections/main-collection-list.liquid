<div class="coll-list-page">
  <div class="container">
    <h1 class="coll-list-page__title">{{ 'collections.title' | t }}</h1>
    <div class="coll-list-page__grid">
      {%- for collection in collections -%}
        {%- if collection.handle != 'all' -%}
          <a href="{{ collection.url }}" class="coll-list-page__card">
            <div class="coll-list-page__card-image">
              {%- if collection.image != blank -%}
                {%- render 'image', image: collection.image, widths: '360,535,750', sizes: '(min-width: 990px) 33vw, 50vw' -%}
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            <div class="coll-list-page__card-info">
              <h2 class="coll-list-page__card-title">{{ collection.title }}</h2>
              <p class="coll-list-page__card-count">{{ collection.products_count }} {{ 'search.items' | t | default: 'items' }}</p>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .coll-list-page { padding: 32px 0 64px; }
  .coll-list-page__title { font-family: 'ITC Avant Garde Gothic Pro Demi', sans-serif; font-size: 32px; color: #313D65; font-weight: normal; text-align: center; margin: 0 0 40px; }
  .coll-list-page__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .coll-list-page__card { text-decoration: none; color: inherit; }
  .coll-list-page__card-image { aspect-ratio: 1/1; overflow: hidden; background: #f5f5f5; }
  .coll-list-page__card-image img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s ease; }
  .coll-list-page__card:hover .coll-list-page__card-image img { transform: scale(1.03); }
  .coll-list-page__card-image svg { width: 100%; height: 100%; }
  .coll-list-page__card-info { padding: 12px 0; text-align: center; }
  .coll-list-page__card-title { font-family: 'ITC Avant Garde Gothic Pro Demi', sans-serif; font-size: 20px; color: #313D65; font-weight: normal; margin: 0 0 4px; }
  .coll-list-page__card-count { font-family: 'Outfit', sans-serif; font-size: 14px; color: #ADADAD; margin: 0; }
  @media (min-width: 750px) and (max-width: 989px) { .coll-list-page__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 749px) { .coll-list-page__title { font-size: 22px; margin-bottom: 24px; } .coll-list-page__grid { grid-template-columns: repeat(2, 1fr); gap: 16px; } .coll-list-page__card-title { font-size: 16px; } }
{% endstylesheet %}

{% schema %}
{ "name": "Collection list page", "settings": [] }
{% endschema %}
