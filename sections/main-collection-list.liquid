{%- liquid
  assign collection_count = 0
  for collection in collections
    unless collection.handle == 'all'
      assign collection_count = collection_count | plus: 1
    endunless
  endfor
-%}

<div class="coll-list-pg">
  <div class="container">
    <div class="coll-list-pg__layout">

      <aside class="coll-list-pg__sidebar">
        <h2 class="coll-list-pg__sidebar-heading">Categories</h2>
        <ul class="coll-list-pg__cats">
          {%- for collection in collections -%}
            {%- unless collection.handle == 'all' -%}
              <li>
                <a href="{{ collection.url }}" class="coll-list-pg__cat-link">
                  {{ collection.title }} <span class="coll-list-pg__cat-count">({{ collection.products_count }})</span>
                </a>
              </li>
            {%- endunless -%}
          {%- endfor -%}
        </ul>
        <div class="coll-list-pg__total">
          <div class="coll-list-pg__total-ring">{{ collection_count }}</div>
          <p class="coll-list-pg__total-label">TOTAL<br>CATEGORIES</p>
        </div>
      </aside>

      <div class="coll-list-pg__grid">
        {%- for collection in collections -%}
          {%- unless collection.handle == 'all' -%}
            <a href="{{ collection.url }}" class="coll-list-pg__card">
              <div class="coll-list-pg__card-img">
                {%- if collection.image != blank -%}
                  {%- render 'image',
                    image: collection.image,
                    widths: '360,535,750',
                    sizes: '(min-width: 990px) 25vw, 50vw'
                  -%}
                {%- else -%}
                  {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
              <h2 class="coll-list-pg__card-title">{{ collection.title }}</h2>
            </a>
          {%- endunless -%}
        {%- endfor -%}
      </div>

    </div>
  </div>
</div>

{% stylesheet %}
  .coll-list-pg {
    padding-bottom: 64px;
  }

  .coll-list-pg__layout {
    display: grid;
    grid-template-columns: 30% 1fr;
    gap: 24px;
    align-items: start;
  }

  /* ── Sidebar (matches collection page) ── */
  .coll-list-pg__sidebar {
    position: sticky;
    top: 120px;
  }

  .coll-list-pg__sidebar-heading {
    font-family: 'Outfit', sans-serif;
    font-size: 32px;
    line-height: 1.2;
    color: #313D65;
    font-weight: normal;
    margin: 0 0 16px;
  }

  .coll-list-pg__cats {
    list-style: none;
    padding: 0 0 24px;
    margin: 0;
    border-bottom: 1px solid #DFDFDF;
  }

  .coll-list-pg__cat-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    height: 48px;
    padding: 0 16px;
    background-color: #8FA1B7;
    font-family: 'Outfit', sans-serif;
    font-size: 18px;
    font-weight: 600;
    color: #fff;
    text-decoration: none;
    text-transform: capitalize;
    margin-bottom: 8px;
    transition: background-color 0.2s ease;
  }

  .coll-list-pg__cat-link:hover {
    background-color: #7a8fa5;
  }

  .coll-list-pg__cat-count {
    font-size: 14px;
    font-weight: 400;
    opacity: 0.8;
  }

  .coll-list-pg__total {
    padding-top: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .coll-list-pg__total-ring {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    border: 1px solid #ADADAD;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Outfit', sans-serif;
    font-size: 20px;
    font-weight: 400;
    color: #353535;
  }

  .coll-list-pg__total-label {
    font-family: 'Outfit', sans-serif;
    font-size: 11px;
    font-weight: 600;
    color: #ADADAD;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    line-height: 1.6;
    margin: 0;
  }

  /* ── Grid (3 columns to match collection 2-col + sidebar proportion) ── */
  .coll-list-pg__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .coll-list-pg__card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .coll-list-pg__card-img {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: #f5f5f5;
  }

  .coll-list-pg__card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .coll-list-pg__card:hover .coll-list-pg__card-img img {
    transform: scale(1.03);
  }

  .coll-list-pg__card-img svg {
    width: 100%;
    height: 100%;
  }

  .coll-list-pg__card-title {
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: #0C0C0C;
    margin: 12px 0 0;
    line-height: 1.4;
  }

  /* ── Tablet ── */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .coll-list-pg__layout {
      grid-template-columns: 30% 1fr;
      gap: 20px;
    }

    .coll-list-pg__sidebar-heading {
      font-size: 24px;
    }

    .coll-list-pg__cat-link {
      font-size: 16px;
      height: 42px;
    }

    .coll-list-pg__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    .coll-list-pg {
      padding-bottom: 40px;
    }

    .coll-list-pg__layout {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .coll-list-pg__sidebar {
      position: static;
    }

    .coll-list-pg__sidebar-heading {
      font-size: 24px;
    }

    .coll-list-pg__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .coll-list-pg__card-title {
      font-size: 13px;
    }
  }
{% endstylesheet %}

{% schema %}
{ "name": "Collection list page", "settings": [] }
{% endschema %}
