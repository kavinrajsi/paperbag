<div class="wishlist-page" data-section-id="{{ section.id }}">
  <div class="container">
    <h1 class="wishlist-page__heading">{{ section.settings.heading | default: 'My Wish List' }}</h1>
    <p class="wishlist-page__count" data-wishlist-count></p>

    <div class="wishlist-page__grid" data-wishlist-grid></div>

    <div class="wishlist-page__empty" data-wishlist-empty style="display: none;">
      <p class="wishlist-page__empty-text">{{ section.settings.empty_text | default: 'Your wishlist is empty.' }}</p>
      <a href="{{ routes.all_products_collection_url }}" class="wishlist-page__continue-btn">
        {{ 'general.continue_shopping' | t | default: 'Continue Shopping' }}
      </a>
    </div>
  </div>
</div>

{% stylesheet %}
  .wishlist-page {
    padding: 48px 0 80px;
  }

  .wishlist-page__heading {
    font-family: 'ITC Avant Garde Gothic Pro Demi', sans-serif;
    font-size: 32px;
    line-height: 1.2;
    color: #313D65;
    font-weight: normal;
    font-style: normal;
    text-align: center;
    margin: 0 0 12px;
  }

  .wishlist-page__count {
    font-family: 'Outfit', sans-serif;
    font-size: 24px;
    font-weight: 400;
    line-height: 1.8;
    color: #0C0C0C;
    text-transform: capitalize;
    text-align: center;
    margin: 0 0 40px;
  }

  .wishlist-page__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* ── Empty state ── */
  .wishlist-page__empty {
    text-align: center;
    padding: 48px 0;
  }

  .wishlist-page__empty-text {
    font-family: 'Outfit', sans-serif;
    font-size: 18px;
    color: #ADADAD;
    margin: 0 0 24px;
  }

  .wishlist-page__continue-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 40px;
    padding: 0 32px;
    background-color: #313D65;
    color: #FAF8F3;
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 600;
    text-transform: capitalize;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .wishlist-page__continue-btn:hover {
    opacity: 0.9;
  }

  /* ── Wishlist card (rendered via JS) ── */
  .wishlist-card {
    position: relative;
  }

  .wishlist-card__image {
    display: block;
    position: relative;
    aspect-ratio: 392 / 438;
    overflow: hidden;
    background-color: #f5f5f5;
    text-decoration: none;
  }

  .wishlist-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .wishlist-card__image:hover img {
    transform: scale(1.03);
  }

  .wishlist-card__remove {
    position: absolute;
    top: 24px;
    right: 24px;
    z-index: 2;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: #313D65;
    transition: opacity 0.2s ease;
  }

  .wishlist-card__remove:hover {
    opacity: 0.7;
  }

  .wishlist-card__info {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 8px 0;
  }

  .wishlist-card__details {
    flex: 1;
    min-width: 0;
  }

  .wishlist-card__vendor {
    font-family: 'ITC Avant Garde Gothic Pro Demi', sans-serif;
    font-size: 16px;
    line-height: 1.2;
    color: #313D65;
    font-weight: normal;
    margin: 0 0 4px;
  }

  .wishlist-card__title {
    font-family: 'Outfit', sans-serif;
    font-size: 18px;
    font-weight: 400;
    line-height: 1.8;
    color: #0C0C0C;
    text-transform: capitalize;
    margin: 0;
  }

  .wishlist-card__title a {
    color: inherit;
    text-decoration: none;
  }

  .wishlist-card__title a:hover {
    text-decoration: underline;
  }

  .wishlist-card__price {
    flex-shrink: 0;
    font-family: 'Montserrat', sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: #0C0C0C;
  }

  /* ── Tablet ── */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .wishlist-page__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    .wishlist-page {
      padding: 32px 0 56px;
    }

    .wishlist-page__heading {
      font-size: 20px;
      margin-bottom: 8px;
    }

    .wishlist-page__count {
      font-size: 16px;
      margin-bottom: 24px;
    }

    .wishlist-page__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .wishlist-card__image {
      aspect-ratio: 168 / 213;
    }

    .wishlist-card__remove {
      top: 8px;
      right: 14px;
    }

    .wishlist-card__remove .icon {
      width: 18px;
      height: 18px;
    }

    .wishlist-card__info {
      flex-direction: column;
      align-items: flex-start;
      padding: 8px 0 0;
    }

    .wishlist-card__vendor {
      font-size: 14px;
    }

    .wishlist-card__title {
      font-size: 14px;
    }

    .wishlist-card__price {
      font-size: 14px;
      margin-top: 2px;
    }
  }
{% endstylesheet %}

<script>
  (function() {
    var STORAGE_KEY = 'paperbag_wishlist';
    var grid = document.querySelector('[data-wishlist-grid]');
    var countEl = document.querySelector('[data-wishlist-count]');
    var emptyEl = document.querySelector('[data-wishlist-empty]');

    if (!grid) return;

    function getWishlist() {
      try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY)) || [];
      } catch(e) {
        return [];
      }
    }

    function saveWishlist(handles) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(handles));
    }

    function removeFromWishlist(handle) {
      var list = getWishlist().filter(function(h) { return h !== handle; });
      saveWishlist(list);
      loadWishlist();
      window.dispatchEvent(new CustomEvent('wishlist:changed'));
    }

    function renderCard(product) {
      var img = product.featured_image || '';
      var url = '/products/' + encodeURIComponent(product.handle);
      var price = product.price ? (parseInt(product.price, 10) / 100).toFixed(2) : '';
      var card = document.createElement('div');
      card.className = 'wishlist-card';
      card.setAttribute('data-handle', product.handle);

      card.innerHTML =
        '<a href="' + escapeHtml(url) + '" class="wishlist-card__image">' +
          (img ? '<img src="' + escapeHtml(img) + '" alt="' + escapeHtml(product.title) + '" loading="lazy">' : '') +
        '</a>' +
        '<button type="button" class="wishlist-card__remove" data-wishlist-remove="' + escapeHtml(product.handle) + '" aria-label="Remove from wishlist">' +
          '<svg class="icon icon-heart" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>' +
        '</button>' +
        '<div class="wishlist-card__info">' +
          '<div class="wishlist-card__details">' +
            '<h3 class="wishlist-card__title"><a href="' + escapeHtml(url) + '">' + escapeHtml(product.title) + '</a></h3>' +
          '</div>' +
          (price ? '<span class="wishlist-card__price">{{ cart.currency.symbol }}' + price + '</span>' : '') +
        '</div>';

      return card;
    }

    function loadWishlist() {
      var handles = getWishlist();
      grid.innerHTML = '';

      if (handles.length === 0) {
        countEl.textContent = '';
        emptyEl.style.display = 'block';
        return;
      }

      emptyEl.style.display = 'none';
      countEl.textContent = handles.length + ' ' + (handles.length === 1 ? 'item' : 'items');

      var loaded = 0;
      handles.forEach(function(handle) {
        if (!/^[a-z0-9\-]+$/.test(handle)) { loaded++; return; }
        fetch('/products/' + encodeURIComponent(handle) + '.json')
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (data && data.product) {
              grid.appendChild(renderCard(data.product));
            }
            loaded++;
            if (loaded === handles.length) bindRemoveButtons();
          })
          .catch(function() {
            loaded++;
            if (loaded === handles.length) bindRemoveButtons();
          });
      });
    }

    function bindRemoveButtons() {
      var btns = grid.querySelectorAll('[data-wishlist-remove]');
      for (var i = 0; i < btns.length; i++) {
        btns[i].addEventListener('click', function(e) {
          e.preventDefault();
          var handle = this.getAttribute('data-wishlist-remove');
          removeFromWishlist(handle);
        });
      }
    }

    function escapeHtml(str) {
      var div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    loadWishlist();
  })();
</script>

{% schema %}
{
  "name": "Wishlist",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "My Wish List",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "empty_text",
      "default": "Your wishlist is empty.",
      "label": "Empty state text"
    }
  ]
}
{% endschema %}
