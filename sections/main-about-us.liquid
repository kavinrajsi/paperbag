{%- liquid
  assign heading = section.settings.heading
  assign content = section.settings.content
  assign image = section.settings.image
-%}

<section class="about-us-content home-about" style="--ha-bg-color: #ffffff; --ha-heading-color: #313d65; --ha-text-color: #8fa1b7;">
  <div class="home-about__wrapper home-about__wrapper--container">
    <div class="home-about__grid home-about__grid--content-image">

      <div class="home-about__content">
        <div class="section-title__heading">
          {%- if heading != blank -%}
            <h2 class="section-title">{{ heading }}</h2>
          {%- endif -%}

          {%- if content != blank -%}
            <div class="section-content">{{ content }}</div>
          {%- endif -%}
        </div>
      </div>

      <div class="home-about__media">
        {%- if image -%}
          <img
            class="home-about__image"
            src="{{ image | image_url: width: 1000 }}"
            srcset="
              {{ image | image_url: width: 500 }} 500w,
              {{ image | image_url: width: 750 }} 750w,
              {{ image | image_url: width: 1000 }} 1000w
            "
            sizes="(min-width: 990px) 42vw, 65vw"
            alt="{{ image.alt | default: heading | escape }}"
            loading="lazy"
            width="{{ image.width }}"
            height="{{ image.height }}"
          >
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'home-about__placeholder' }}
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{%- comment -%} CMS page content fallback {%- endcomment -%}
{%- if page.content != blank -%}
  <div class="about-us__page-content rte">{{ page.content }}</div>
{%- endif -%}

{% stylesheet %}
  .about-us-content {
    padding: 48px 0 64px;
  }

  /* Page content fallback */
  .about-us__page-content { max-width: 800px; margin: 0 auto; font-family: 'Outfit', sans-serif; font-size: 18px; line-height: 1.8; color: #353535; }
  .about-us__page-content h2, .about-us__page-content h3 { font-family: 'Outfit', sans-serif; color: #313D65; font-weight: normal; }

  @media (max-width: 749px) {
    .about-us-content { padding: 24px 0 40px; }
    .about-us__page-content { font-size: 14px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "About Us",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "About Us"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    }
  ]
}
{% endschema %}
