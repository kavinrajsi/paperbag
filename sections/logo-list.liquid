{%- liquid
  assign heading = section.settings.heading
-%}

<section class="logo-list" data-section-id="{{ section.id }}">
  <div class="container">
    {%- if heading != blank -%}
      <h2 class="logo-list__heading section-heading">{{ heading }}</h2>
    {%- endif -%}

    <div class="logo-list__row">
      {%- for block in section.blocks -%}
        <div class="logo-list__item" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="logo-list__link">
          {%- endif -%}

          {%- if block.settings.image != blank -%}
            {%- render 'image', image: block.settings.image, widths: '100,150,200', sizes: '150px', class: 'logo-list__image' -%}
          {%- else -%}
            <div class="logo-list__placeholder">
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}

          {%- if block.settings.link != blank -%}
            </a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .logo-list {
    padding: 48px 0;
  }

  .logo-list__heading {
    text-align: center;
    margin-bottom: 32px;
  }

  .logo-list__row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 32px;
  }

  .logo-list__item {
    flex: 0 0 auto;
  }

  .logo-list__link {
    display: block;
  }

  .logo-list__image,
  .logo-list__placeholder svg {
    max-height: 48px;
    width: auto;
    display: block;
    filter: grayscale(100%);
    opacity: 0.6;
    transition: filter 0.3s ease, opacity 0.3s ease;
  }

  .logo-list__item:hover .logo-list__image,
  .logo-list__item:hover .logo-list__placeholder svg {
    filter: grayscale(0%);
    opacity: 1;
  }

  @media screen and (max-width: 749px) {
    .logo-list__row {
      gap: 24px;
    }

    .logo-list__image,
    .logo-list__placeholder svg {
      max-height: 36px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.logo_list.name",
  "class": "section-logo-list",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "As seen in",
      "label": "t:sections.logo_list.settings.heading.label"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "t:sections.logo_list.blocks.logo.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.logo_list.blocks.logo.settings.image.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.logo_list.blocks.logo.settings.link.label"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Logo list",
      "blocks": [
        {
          "type": "logo"
        },
        {
          "type": "logo"
        },
        {
          "type": "logo"
        },
        {
          "type": "logo"
        }
      ]
    }
  ]
}
{% endschema %}
