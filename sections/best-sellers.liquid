{%- liquid
  assign collection = section.settings.collection
  assign heading = section.settings.heading
  assign products_to_show = section.settings.products_to_show
  assign show_view_all = section.settings.show_view_all
-%}

<section class="best-sellers" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="best-sellers__header">
      {%- if heading != blank -%}
        <h2 class="best-sellers__heading">{{ heading }}</h2>
      {%- endif -%}

      {%- if show_view_all and collection != blank -%}
        <a href="{{ collection.url }}" class="best-sellers__view-all">
          {{ 'sections.best_sellers.view_all' | t | default: 'View All' }}
        </a>
      {%- endif -%}
    </div>

    {%- if collection != blank -%}
      <div class="best-sellers__grid">
        {%- for product in collection.products limit: 4 -%}
          <div class="best-sellers__item">
            {%- render 'best-sellers-card', product: product -%}
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="best-sellers__grid">
        {%- for i in (1..products_to_show) -%}
          <div class="best-sellers__item">
            <div class="best-seller-card">
              <div class="best-seller-card__image-wrap">
                {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
              <div class="best-seller-card__info">
                <div class="best-seller-card__details">
                  <h3 class="best-seller-card__title">Product Title</h3>
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  /* ── Header ── */
  .best-sellers {
    padding: 64px 0;
  }

  .best-sellers__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .best-sellers__heading {
    font-family: 'Outfit', sans-serif;
    font-size: 20px;
    line-height: 1.4;
    color: #313D65;
    font-weight: normal;
    font-style: normal;
    margin: 0;
  }

  .best-sellers__view-all--mobile-hidden {
    display: none;
  }

  .best-sellers__view-all {
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: #313D65;
    text-transform: capitalize;
    text-decoration: none;
    white-space: nowrap;
  }

  .best-sellers__view-all:hover {
    text-decoration: underline;
  }

  /* ── Grid (mobile-first: horizontal scroll) ── */
  .best-sellers {
    padding: 40px 0;
  }

  .best-sellers__grid {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    gap: 16px;
    scrollbar-width: none;
  }

  .best-sellers__grid::-webkit-scrollbar {
    display: none;
  }

  .best-sellers__item {
    flex: 0 0 calc(66.666% - 8px);
    scroll-snap-align: start;
  }

  /* ── Card ── */
  .best-seller-card__image-wrap {
    display: block;
    position: relative;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .best-seller-card__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .best-seller-card__image-wrap svg {
    width: 100%;
    height: 100%;
  }

  .best-seller-card__wishlist {
    position: absolute;
    top: 8px;
    right: 14px;
    z-index: 2;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: #313D65;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  .best-seller-card__wishlist:hover {
    opacity: 1;
  }

  .best-seller-card__wishlist .icon {
    width: 18px;
    height: 18px;
  }

  .best-seller-card__info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 8px 0 0;
  }

  .best-seller-card__details {
    flex: 1;
    min-width: 0;
  }

  .best-seller-card__vendor {
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    line-height: 1.2;
    color: #313D65;
    font-weight: normal;
    font-style: normal;
    margin: 0 0 4px;
  }

  .best-seller-card__title {
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.8;
    color: #0C0C0C;
    text-transform: capitalize;
    margin: 0 0 4px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .best-seller-card__title a {
    color: inherit;
    text-decoration: none;
  }

  .best-seller-card__title a:hover {
    text-decoration: underline;
  }

  .best-seller-card__swatches {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-top: 4px;
  }

  .best-seller-card__swatch {
    display: block;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.1);
  }

  .best-seller-card__price {
    flex-shrink: 0;
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: #0C0C0C;
    margin-top: 2px;
  }

  /* Scroll dots */
  .best-sellers__dots {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 4px;
    margin-top: 20px;
  }

  .best-sellers__dot {
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #DFDFDF;
    transition: all 0.2s ease;
  }

  .best-sellers__dot--active {
    width: 12px;
    height: 12px;
    background-color: #313D65;
  }

  /* ── Tablet (750px–989px): 3 visible with scroll ── */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .best-sellers__item {
      flex: 0 0 calc(33.333% - 11px);
    }
  }

  /* ── Desktop (min-width: 990px) ── */
  @media screen and (min-width: 990px) {
    .best-sellers {
      padding: 64px 0;
    }

    .best-sellers__heading {
      font-size: 32px;
      line-height: 1.2;
    }

    .best-sellers__grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
      overflow: visible;
    }

    .best-sellers__item {
      flex: none;
    }

    .best-seller-card__image-wrap {
    }

    .best-seller-card__wishlist {
      top: 24px;
      right: 24px;
    }

    .best-seller-card__wishlist .icon {
      width: 24px;
      height: 24px;
    }

    .best-seller-card__info {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      padding: 12px 8px 0;
    }

    .best-seller-card__vendor {
      font-size: 16px;
    }

    .best-seller-card__title {
      font-size: 18px;
    }

    .best-seller-card__price {
      font-size: 16px;
      margin-top: 0;
    }

    .best-sellers__dots {
      display: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function() {
    var section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;

    var grid = section.querySelector('.best-sellers__grid');
    var dots = section.querySelectorAll('.best-sellers__dot');
    if (!grid || dots.length === 0) return;

    function updateDots() {
      var scrollLeft = grid.scrollLeft;
      var itemWidth = grid.querySelector('.best-sellers__item').offsetWidth + 16;
      var activeIndex = Math.round(scrollLeft / itemWidth);
      dots.forEach(function(dot, i) {
        dot.classList.toggle('best-sellers__dot--active', i === activeIndex);
      });
    }

    grid.addEventListener('scroll', updateDots, { passive: true });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.best_sellers.name",
  "class": "section-best-sellers",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Best Sellers",
      "label": "t:sections.best_sellers.settings.heading.label"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.best_sellers.settings.collection.label"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 3,
      "label": "t:sections.best_sellers.settings.products_to_show.label"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "t:sections.best_sellers.settings.show_view_all.label"
    }
  ],
  "presets": [
    {
      "name": "Best Sellers"
    }
  ]
}
{% endschema %}
