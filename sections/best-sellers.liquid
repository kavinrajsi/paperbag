{%- liquid
  assign collection = section.settings.collection
  assign products_count = section.settings.products_count
  assign title = section.settings.title
  assign show_title = section.settings.show_title
  assign columns = section.settings.columns
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign bg_color = section.settings.bg_color
  assign text_color = section.settings.text_color
  assign show_view_all = section.settings.show_view_all
  assign view_all_label = section.settings.view_all_label
-%}

{%- if collection != blank and collection.products.size > 0 -%}
  <section
    class="best-sellers"
    style="
      --bs-padding-top: {{ padding_top }}px;
      --bs-padding-bottom: {{ padding_bottom }}px;
      --bs-bg-color: {{ bg_color }};
      --bs-text-color: {{ text_color }};
    "
    data-section-id="{{ section.id }}"
  >
    <div class="best-sellers__wrapper container">

      {%- if show_title and title != blank -%}
        <div class="best-sellers__header">
          <h2 class="best-sellers__title">{{ title }}</h2>
        </div>
      {%- endif -%}

      <div class="best-sellers__grid best-sellers__grid--{{ columns }}">
        {%- for product in collection.products limit: products_count -%}
          {%- assign current_variant = product.selected_or_first_available_variant -%}
          <div class="best-sellers__item">
            <div class="scroll-collection__card">
              <a href="{{ product.url }}" class="scroll-collection__media">
                {%- if product.featured_image -%}
                  <img
                    class="scroll-collection__image"
                    src="{{ product.featured_image | image_url }}"
                    alt="{{ product.title | escape }}"
                    loading="lazy"
                  >
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'scroll-collection__placeholder' }}
                {%- endif -%}
              </a>
              <div class="scroll-collection__body">
                <div class="scroll-collection__info">
                  <p class="scroll-collection__name">
                    <a href="{{ product.url }}">{{ product.title }}</a>
                  </p>
                  <p class="scroll-collection__price">
                    {{ current_variant.price | money }}
                  </p>
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

      {%- if show_view_all and collection.url != blank -%}
        <div class="best-sellers__view-all">
          <a href="{{ collection.url }}" class="btn btn--primary">
            {{ view_all_label }}
          </a>
        </div>
      {%- endif -%}

    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Best sellers",
  "class": "section-best-sellers",
  "settings": [
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "header",
      "content": "Section title"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show title",
      "default": true
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Best Sellers"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns (desktop)",
      "default": "4",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 56,
      "unit": "px",
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 56,
      "unit": "px",
      "label": "Padding bottom"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1816"
    },
    {
      "type": "header",
      "content": "View all"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show view all button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "Button label",
      "default": "View All"
    }
  ],
  "presets": [
    {
      "name": "Best sellers"
    }
  ]
}
{% endschema %}
