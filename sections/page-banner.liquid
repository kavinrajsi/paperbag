{%- if section.settings.image_desktop != blank or section.settings.image_mobile != blank -%}
  <div class="page-banner">
    <div class="page-banner__media">
      {%- if section.settings.image_mobile != blank -%}
        <img
          class="page-banner__image page-banner__image--mobile"
          src="{{ section.settings.image_mobile | image_url: width: 800 }}"
          srcset="
            {{ section.settings.image_mobile | image_url: width: 400 }} 400w,
            {{ section.settings.image_mobile | image_url: width: 600 }} 600w,
            {{ section.settings.image_mobile | image_url: width: 800 }} 800w
          "
          sizes="100vw"
          alt="{{ section.settings.image_mobile.alt | default: section.settings.heading | escape }}"
          loading="eager"
          width="{{ section.settings.image_mobile.width }}"
          height="{{ section.settings.image_mobile.height }}"
        >
      {%- endif -%}
      {%- if section.settings.image_desktop != blank -%}
        <img
          class="page-banner__image page-banner__image--desktop"
          src="{{ section.settings.image_desktop | image_url: width: 1920 }}"
          srcset="
            {{ section.settings.image_desktop | image_url: width: 1200 }} 1200w,
            {{ section.settings.image_desktop | image_url: width: 1600 }} 1600w,
            {{ section.settings.image_desktop | image_url: width: 1920 }} 1920w
          "
          sizes="100vw"
          alt="{{ section.settings.image_desktop.alt | default: section.settings.heading | escape }}"
          loading="eager"
          width="{{ section.settings.image_desktop.width }}"
          height="{{ section.settings.image_desktop.height }}"
        >
      {%- endif -%}
    </div>
    {%- if section.settings.heading != blank or section.settings.text != blank -%}
      <div class="page-banner__content">
        {%- if section.settings.heading != blank -%}
          <h1 class="page-banner__heading">{{ section.settings.heading }}</h1>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <p class="page-banner__text">{{ section.settings.text }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
{%- endif -%}

{% stylesheet %}
  .page-banner {
    position: relative;
    width: 100%;
    overflow: hidden;
    margin-bottom: 48px;
  }

  @media screen and (min-width: 750px) {
    .page-banner {
      margin-bottom: 64px;
    }
  }

  .page-banner__media {
    width: 100%;
  }

  .page-banner__image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    min-height: 300px;
  }

  .page-banner__image--mobile {
    display: block;
  }

  .page-banner__image--desktop {
    display: none;
  }

  @media screen and (min-width: 750px) {
    .page-banner__image--mobile { display: none; }
    .page-banner__image--desktop { display: block; min-height: 400px; }
  }

  .page-banner__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 32px 16px;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.45));
    color: #fff;
  }

  @media screen and (min-width: 750px) {
    .page-banner__content {
      padding: 48px;
      max-width: 600px;
    }
  }

  .page-banner__heading {
    font-family: 'Outfit', sans-serif;
    font-size: 28px;
    font-weight: 300;
    line-height: 1.2;
    margin: 0 0 8px;
    color: #fff;
  }

  @media screen and (min-width: 750px) {
    .page-banner__heading {
      font-size: 48px;
    }
  }

  .page-banner__text {
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.6;
    margin: 0;
    color: rgba(255, 255, 255, 0.85);
  }

  @media screen and (min-width: 750px) {
    .page-banner__text {
      font-size: 16px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Page Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Banner image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Banner image (mobile)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text"
    }
  ],
  "presets": [
    {
      "name": "Page Banner"
    }
  ]
}
{% endschema %}
