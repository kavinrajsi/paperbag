{%- liquid
  assign heading = section.settings.heading
  assign branded_text = section.settings.branded_text
  assign branded_button_label = section.settings.branded_button_label
  assign branded_button_link = section.settings.branded_button_link
  assign branded_image = section.settings.branded_image
  assign blocks = section.blocks
-%}

<section class="our-collections" data-section-id="{{ section.id }}">
  <div class="container">
    {%- if heading != blank -%}
      <h2 class="our-collections__heading">{{ heading }}</h2>
    {%- endif -%}

    <div class="our-collections__mosaic">
      {%- comment -%} Left column: block 0 (top) + block 1 (bottom) {%- endcomment -%}
      <div class="our-collections__col our-collections__col--left">
        {%- for block in blocks -%}
          {%- if forloop.index == 1 or forloop.index == 2 -%}
            <div class="our-collections__card our-collections__card--{{ forloop.index }}" {{ block.shopify_attributes }}>
              <a href="{{ block.settings.collection.url | default: '#' }}" class="our-collections__card-link" aria-label="{{ block.settings.button_label | escape }}">
                {%- if block.settings.image != blank -%}
                  {%- render 'image',
                    image: block.settings.image,
                    widths: '360,535,600,750,1000',
                    sizes: '(min-width: 990px) 600px, calc(50vw - 28px)'
                  -%}
                {%- else -%}
                  <div class="our-collections__placeholder">
                    {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
                  </div>
                {%- endif -%}

                {%- if block.settings.button_label != blank -%}
                  <span class="our-collections__label">{{ block.settings.button_label }}</span>
                {%- endif -%}
              </a>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- comment -%} Right column: block 2 (top) + branded block (bottom) {%- endcomment -%}
      <div class="our-collections__col our-collections__col--right">
        {%- for block in blocks -%}
          {%- if forloop.index == 3 -%}
            <div class="our-collections__card our-collections__card--3" {{ block.shopify_attributes }}>
              <a href="{{ block.settings.collection.url | default: '#' }}" class="our-collections__card-link" aria-label="{{ block.settings.button_label | escape }}">
                {%- if block.settings.image != blank -%}
                  {%- render 'image',
                    image: block.settings.image,
                    widths: '360,535,600,750,1000',
                    sizes: '(min-width: 990px) 600px, calc(50vw - 28px)'
                  -%}
                {%- else -%}
                  <div class="our-collections__placeholder">
                    {{ 'collection-3' | placeholder_svg_tag: 'placeholder-svg' }}
                  </div>
                {%- endif -%}

                {%- if block.settings.button_label != blank -%}
                  <span class="our-collections__label">{{ block.settings.button_label }}</span>
                {%- endif -%}
              </a>
            </div>
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%} Branded block {%- endcomment -%}
        <div class="our-collections__branded">
          <a href="{{ branded_button_link | default: '#' }}" class="our-collections__branded-link">
            {%- if branded_image != blank -%}
              <div class="our-collections__branded-watermark">
                {%- render 'image', image: branded_image, widths: '200,400', sizes: '300px' -%}
              </div>
            {%- endif -%}

            {%- if branded_text != blank -%}
              <p class="our-collections__branded-text">{{ branded_text }}</p>
            {%- endif -%}

            {%- if branded_button_label != blank -%}
              <span class="our-collections__label our-collections__label--branded">{{ branded_button_label }}</span>
            {%- endif -%}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .our-collections {
    padding: 64px 0;
  }

  .our-collections__heading {
    font-family: 'ITC Avant Garde Gothic Pro Demi', sans-serif;
    font-size: 32px;
    line-height: 1.2;
    color: #313D65;
    font-weight: normal;
    font-style: normal;
    margin: 0 0 32px;
  }

  /* ── Mosaic grid ── */
  .our-collections__mosaic {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .our-collections__col {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* Desktop height ratios via flex-grow */
  .our-collections__card--1 {
    flex-grow: 518;
  }

  .our-collections__card--2 {
    flex-grow: 837;
  }

  .our-collections__card--3 {
    flex-grow: 840;
  }

  .our-collections__branded {
    flex-grow: 467;
  }

  /* ── Card shared ── */
  .our-collections__card-link {
    display: block;
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    text-decoration: none;
  }

  .our-collections__card-link img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .our-collections__card-link:hover img {
    transform: scale(1.03);
  }

  .our-collections__placeholder {
    width: 100%;
    height: 100%;
    background-color: #f5f5f5;
  }

  .our-collections__placeholder svg {
    width: 100%;
    height: 100%;
  }

  /* ── Collection label buttons ── */
  .our-collections__label {
    position: absolute;
    bottom: 16px;
    background: #FFFFFF;
    padding: 8px 24px;
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #313D65;
    text-transform: capitalize;
    line-height: 1.8;
    white-space: nowrap;
    z-index: 2;
  }

  /* Position: blocks 1 & 2 (left col) → label at bottom-right */
  .our-collections__card--1 .our-collections__label,
  .our-collections__card--2 .our-collections__label {
    right: 16px;
  }

  /* Position: block 3 (right col top) → label at bottom-left */
  .our-collections__card--3 .our-collections__label {
    left: 16px;
  }

  /* ── Branded block ── */
  .our-collections__branded {
    position: relative;
    background-color: #8FA1B7;
    overflow: hidden;
  }

  .our-collections__branded-link {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    position: relative;
    width: 100%;
    height: 100%;
    padding: 24px;
    text-decoration: none;
  }

  .our-collections__branded-watermark {
    position: absolute;
    bottom: -10%;
    right: -5%;
    width: 55%;
    opacity: 0.35;
    pointer-events: none;
  }

  .our-collections__branded-watermark img {
    width: 100%;
    height: auto;
    display: block;
  }

  .our-collections__branded-text {
    font-family: 'ITC Avant Garde Gothic Pro Demi', sans-serif;
    font-size: 14px;
    color: #FAF8F3;
    line-height: 1.5;
    margin: 0;
    position: relative;
    z-index: 2;
    display: none;
  }

  .our-collections__label--branded {
    position: relative;
    bottom: auto;
    left: auto;
    display: inline-block;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 989px) {
    .our-collections {
      padding: 40px 0;
    }

    .our-collections__heading {
      font-size: 20px;
      line-height: 1.4;
      margin-bottom: 16px;
    }

    .our-collections__mosaic {
      gap: 16px;
    }

    .our-collections__col {
      gap: 24px;
    }

    /* Mobile height ratios */
    .our-collections__card--1 {
      flex-grow: 165;
    }

    .our-collections__card--2 {
      flex-grow: 253;
    }

    .our-collections__card--3 {
      flex-grow: 276;
    }

    .our-collections__branded {
      flex-grow: 131;
    }

    .our-collections__label {
      bottom: 10px;
      padding: 6px 16px;
      font-size: 14px;
    }

    .our-collections__card--1 .our-collections__label,
    .our-collections__card--2 .our-collections__label {
      left: 11px;
      right: auto;
    }

    .our-collections__card--3 .our-collections__label {
      left: 11px;
    }

    /* Show branded text on mobile */
    .our-collections__branded-text {
      display: block;
      font-size: 12px;
      margin-bottom: 12px;
    }

    .our-collections__branded-link {
      flex-direction: column;
      align-items: flex-start;
      justify-content: center;
      padding: 16px;
    }

    .our-collections__label--branded {
      padding: 6px 16px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.our_collections.name",
  "class": "section-our-collections",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Shop Our Collections",
      "label": "t:sections.our_collections.settings.heading.label"
    },
    {
      "type": "text",
      "id": "branded_text",
      "default": "Wardrobe essentials, redefined.",
      "label": "t:sections.our_collections.settings.branded_text.label"
    },
    {
      "type": "text",
      "id": "branded_button_label",
      "default": "Shop Collection",
      "label": "t:sections.our_collections.settings.branded_button_label.label"
    },
    {
      "type": "url",
      "id": "branded_button_link",
      "label": "t:sections.our_collections.settings.branded_button_link.label"
    },
    {
      "type": "image_picker",
      "id": "branded_image",
      "label": "t:sections.our_collections.settings.branded_image.label"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "t:sections.our_collections.blocks.collection.name",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:sections.our_collections.blocks.collection.settings.collection.label"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.our_collections.blocks.collection.settings.image.label"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "t:sections.our_collections.blocks.collection.settings.button_label.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Our Collections",
      "blocks": [
        {
          "type": "collection",
          "settings": {
            "button_label": "Summer Collection"
          }
        },
        {
          "type": "collection",
          "settings": {
            "button_label": "Office Collection"
          }
        },
        {
          "type": "collection",
          "settings": {
            "button_label": "Fall Collection"
          }
        }
      ]
    }
  ]
}
{% endschema %}
