<div class="contact-us">
  <div class="container">

    <div class="contact-us__layout">
      {%- comment -%} Left: Contact info with icons {%- endcomment -%}

      <div class="contact-us__info">
    <h1 class="contact-us__title">{{ section.settings.heading | default: page.title }}</h1>
        {%- if section.settings.phone != blank -%}
          <div class="contact-us__detail">
            <div class="contact-us__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
            </div>
            <div class="contact-us__detail-content">
              <h3 class="contact-us__detail-heading">
                <a href="tel:{{ section.settings.phone | remove: ' ' }}">{{ section.settings.phone }}</a>
              </h3>
              {%- if section.settings.phone_hours != blank -%}
                <p class="contact-us__detail-text">{{ section.settings.phone_hours }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.email != blank -%}
          <div class="contact-us__detail">
            <div class="contact-us__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div class="contact-us__detail-content">
              <h3 class="contact-us__detail-heading">
                <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
              </h3>
              {%- if section.settings.email_note != blank -%}
                <p class="contact-us__detail-text">{{ section.settings.email_note }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Right: Contact form {%- endcomment -%}
      <div class="contact-us__form-wrap">
        <h2 class="contact-us__form-heading">{{ section.settings.form_heading | default: 'Drop us a message' }}</h2>

        {% form 'contact' %}
          {%- if form.posted_successfully? -%}
            <p class="contact-us__success">{{ 'contact.form.success' | t }}</p>
          {%- endif -%}
          {%- if form.errors -%}
            <div class="contact-us__error">{{ form.errors | default_errors }}</div>
          {%- endif -%}

          <div class="contact-us__field">
            <input type="text" name="contact[{{ 'contact.form.name' | t }}]" required class="contact-us__input" placeholder="Your Name *">
          </div>
          <div class="contact-us__field">
            <input type="email" name="contact[email]" required class="contact-us__input" placeholder="Your Email *">
          </div>
          <div class="contact-us__field">
            <input type="tel" name="contact[{{ 'contact.form.phone' | t }}]" class="contact-us__input" placeholder="Contact No. *">
          </div>
          <div class="contact-us__field">
            <textarea name="contact[{{ 'contact.form.message' | t }}]" required class="contact-us__input contact-us__textarea" rows="6" placeholder="Message"></textarea>
          </div>
          <button type="submit" class="contact-us__submit">Send Message</button>
        {% endform %}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .contact-us {
    padding: 48px 0 80px;
  }

  .contact-us__title {
    font-family: 'Outfit', sans-serif;
    font-size: 48px;
    font-weight: 300;
    color: #8FA1B7;
    line-height: 1.1;
  }

  .contact-us__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  /* ── Info column ── */
  .contact-us__info {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .contact-us__detail {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .contact-us__icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1.5px solid #0C0C0C;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #0C0C0C;
  }

  .contact-us__detail-content {
    padding-top: 4px;
  }

  .contact-us__detail-heading {
    font-family: 'Outfit', sans-serif;
    font-size: 18px;
    font-weight: 500;
    color: #8fa1b7;
    margin: 0 0 4px;
    line-height: 1.3;
  }

  .contact-us__detail-heading a {
    color: inherit;
    text-decoration: none;
  }

  .contact-us__detail-heading a:hover {
    text-decoration: underline;
  }

  .contact-us__detail-text {
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: #606060;
    margin: 0;
    line-height: 1.6;
  }

  /* ── Form column ── */
  .contact-us__form-heading {
    font-family: 'Outfit', sans-serif;
    font-size: 28px;
    font-weight: 500;
    color: #8fa1b7;
    margin: 0 0 28px;
  }

  .contact-us__field {
    margin-bottom: 20px;
  }

  .contact-us__input {
    width: 100%;
    height: 52px;
    padding: 0 16px;
    border: 1.5px solid #8FA1B7;
    background: #fff;
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: #0C0C0C;
    outline: none;
    box-sizing: border-box;
    transition: border-color 0.2s;
  }

  .contact-us__input::placeholder {
    color: #999;
  }

  .contact-us__input:focus {
    border-color: #606060;
  }

  .contact-us__textarea {
    height: auto;
    padding: 16px;
    resize: vertical;
    min-height: 140px;
  }

  .contact-us__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 48px;
    padding: 0 40px;
    background-color: #8FA1B7;
    border: none;
    border-radius: 8px;
    color: #fff;
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: 600;
    text-transform: capitalize;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .contact-us__submit:hover {
    opacity: 0.85;
  }

  .contact-us__success {
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    color: #2e7d32;
    margin: 0 0 16px;
  }

  .contact-us__error {
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    color: #c62828;
    margin: 0 0 16px;
  }

  @media (max-width: 989px) {
    .contact-us__layout {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }

  @media (max-width: 749px) {
    .contact-us__title {
      font-size: 32px;
    }

    .contact-us__form-heading {
      font-size: 22px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Contact Us",
  "settings": [
    { "type": "text", "id": "heading", "default": "Contact Us", "label": "Heading" },
    { "type": "text", "id": "phone", "default": "+1 (800) 123-4567", "label": "Phone" },
    { "type": "text", "id": "phone_hours", "default": "Mon - Fri, 10:00 - 6:30 IST", "label": "Phone hours" },
    { "type": "text", "id": "email", "default": "hello@paperbag.store", "label": "Email" },
    { "type": "text", "id": "email_note", "default": "Typical response time: 24 hours", "label": "Email note" },
    { "type": "text", "id": "form_heading", "default": "Drop us a message", "label": "Form heading" }
  ]
}
{% endschema %}
