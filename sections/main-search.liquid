{%- paginate search.results by 24 -%}
<div class="search-page" data-section-id="{{ section.id }}">
  <div class="container">
    <form action="{{ routes.search_url }}" method="get" class="search-page__form">
      <div class="search-page__input-wrap">
        {%- render 'icon', icon: 'search' -%}
        <input
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="{{ 'search.placeholder' | t }}"
          class="search-page__input"
          autocomplete="off"
          autocorrect="off"
          autocapitalize="off"
          autofocus
        >
        {%- if search.terms != blank -%}
          <a href="{{ routes.search_url }}" class="search-page__clear" aria-label="{{ 'general.close' | t }}">
            {%- render 'icon', icon: 'close', size: 20 -%}
          </a>
        {%- endif -%}
      </div>
      <input type="hidden" name="type" value="product">
    </form>

    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}
        <div class="search-page__toolbar">
          <span class="search-page__count">{{ search.results_count }} Products</span>
        </div>

        <div class="search-page__grid">
          {%- for result in search.results -%}
            {%- if result.object_type == 'product' -%}
              {%- assign current_variant = result.selected_or_first_available_variant -%}
              <div class="collection-page__item">
                <div class="scroll-collection__card">
                  <a href="{{ result.url }}" class="scroll-collection__media">
                    {%- if result.featured_image -%}
                      <img
                        class="scroll-collection__image"
                        src="{{ result.featured_image | image_url }}"
                        alt="{{ result.title | escape }}"
                        loading="lazy"
                      >
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'scroll-collection__placeholder' }}
                    {%- endif -%}
                  </a>
                  <div class="scroll-collection__body">
                    <div class="scroll-collection__info">
                      <p class="scroll-collection__name">
                        <a href="{{ result.url }}">{{ result.title }}</a>
                      </p>
                      <p class="scroll-collection__price">
                        {{ current_variant.price | money_without_trailing_zeros }}
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          {%- render 'pagination', paginate: paginate -%}
        {%- endif -%}
      {%- else -%}
        <p class="search-page__empty">
          {{ 'search.no_results' | t: terms: search.terms }}
        </p>
      {%- endif -%}
    {%- endif -%}
  </div>
</div>
{%- endpaginate -%}

{% stylesheet %}
  .search-page {
    padding: 32px 0 64px;
  }

  /* ── Search input ── */
  .search-page__form {
    margin-bottom: 24px;
  }

  .search-page__input-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid #748C70;
    padding: 8px 16px 12px;
  }

  .search-page__input-wrap .icon {
    flex-shrink: 0;
    color: #ADADAD;
  }

  .search-page__input {
    flex: 1;
    border: none;
    outline: none;
    background: none;
    font-family: 'Outfit', sans-serif;
    font-size: 20px;
    font-weight: 400;
    line-height: 1.8;
    color: #0C0C0C;
    text-transform: capitalize;
  }

  .search-page__input::placeholder {
    color: #ADADAD;
    text-transform: capitalize;
  }

  .search-page__clear {
    flex-shrink: 0;
    color: #ADADAD;
    display: flex;
    align-items: center;
    transition: color 0.2s ease;
  }

  .search-page__clear:hover {
    color: #313D65;
  }

  /* ── Toolbar ── */
  .search-page__toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .search-page__count {
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: var(--color-text);
    margin: 0;
  }

  /* ── Product grid: matches collection page ── */
  .search-page__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 30px;
  }

  @media screen and (min-width: 750px) {
    .search-page__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }

  @media screen and (min-width: 990px) {
    .search-page__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* ── Empty state ── */
  .search-page__empty {
    font-family: 'Outfit', sans-serif;
    font-size: 18px;
    color: #ADADAD;
    text-align: center;
    padding: 48px 0;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    .search-page {
      padding: 24px 0 48px;
    }

    .search-page__input-wrap {
      padding: 4px 0 8px;
    }

    .search-page__input {
      font-size: 14px;
      line-height: 1.4;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Search page",
  "settings": []
}
{% endschema %}
