{%- comment -%} Product JSON for JS {%- endcomment -%}
<script type="application/json" data-product-json>
  {{ product | json }}
</script>

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign color_option_index = nil
  for option in product.options_with_values
    assign option_name_lower = option.name | downcase
    if option_name_lower == 'color' or option_name_lower == 'colour'
      assign color_option_index = forloop.index0
      assign color_values = option.values
    endif
  endfor
-%}

<div class="pdp" data-product-section>
  <div class="container">
    <div class="pdp__main">
      {%- comment -%} Gallery {%- endcomment -%}
      <div class="pdp__gallery">
        {%- if product.images.size > 1 -%}
          <div class="pdp__thumbs" data-gallery-thumbs>
            {%- for image in product.images -%}
              <button
                class="pdp__thumb{% if forloop.first %} pdp__thumb--active{% endif %}"
                data-gallery-thumb="{{ forloop.index0 }}"
                data-image-url="{{ image | image_url: width: 1000 }}"
                {%- assign thumb_widths = '360,535,750,1000' | split: ',' -%}
                data-image-srcset="{%- for width in thumb_widths -%}{{ image | image_url: width: width }} {{ width }}w{%- unless forloop.last -%}, {%- endunless -%}{%- endfor -%}"
                aria-label="View image {{ forloop.index }}"
              >
                <img
                  src="{{ image | image_url: width: 125 }}"
                  alt="{{ image.alt | escape | default: product.title }}"
                  loading="lazy"
                >
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <div class="pdp__main-image" data-gallery-main>
          {%- if product.featured_image != blank -%}
            {%- render 'image',
              image: product.featured_image,
              widths: '360,535,750,1000',
              sizes: '(min-width: 990px) 450px, 100vw',
              lazy: false,
              class: 'pdp__image'
            -%}
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Product Info {%- endcomment -%}
      <div class="pdp__info">
        <h1 class="pdp__title">{{ product.title }}</h1>

        {%- if product.description != blank -%}
          <p class="pdp__description">{{ product.description | strip_html | truncatewords: 30 }}</p>
        {%- endif -%}

        <p class="pdp__price" data-pdp-price>{{ current_variant.price | money }}</p>

        {%- if color_option_index != nil and color_values.size > 0 -%}
          <div class="pdp__option-group">
            <p class="pdp__label">{{ 'products.product.color' | t | default: 'Color' }}: <span class="pdp__label-value" data-color-label>{{ product.options[color_option_index] }}</span></p>
            <div class="pdp__color-swatches">
              {%- for color in color_values -%}
                <button
                  type="button"
                  class="pdp__swatch{% if product.options[color_option_index] == color %} pdp__swatch--selected{% endif %}"
                  style="background-color: {{ color | downcase | replace: ' ', '' | escape }};"
                  data-option-index="{{ color_option_index }}"
                  data-option-value="{{ color | escape }}"
                  title="{{ color | escape }}"
                ></button>
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} Size / other options as buttons {%- endcomment -%}
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            {%- assign opt_lower = option.name | downcase -%}
            {%- unless opt_lower == 'color' or opt_lower == 'colour' -%}
              {%- assign opt_idx = forloop.index0 -%}
              <div class="pdp__option-group">
                <p class="pdp__label">{{ option.name }}: <span class="pdp__label-value">{{ option.selected_value }}</span></p>
                <div class="pdp__option-buttons">
                  {%- for value in option.values -%}
                    <button
                      type="button"
                      class="pdp__option-btn{% if option.selected_value == value %} pdp__option-btn--selected{% endif %}"
                      data-option-index="{{ opt_idx }}"
                      data-option-value="{{ value | escape }}"
                    >
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>
              </div>
            {%- endunless -%}
          {%- endfor -%}
        {%- endunless -%}

        {%- comment -%} Quantity + Add to cart {%- endcomment -%}
        {%- form 'product', product -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>

          <div class="pdp__option-group">
            <p class="pdp__label">{{ 'products.product.quantity' | t | default: 'Quantity' }}</p>
            <div class="pdp__cart-row">
              <div class="pdp__qty">
                <button type="button" class="pdp__qty-btn" data-qty-minus aria-label="Decrease quantity">&minus;</button>
                <input type="number" name="quantity" value="1" min="1" class="pdp__qty-input" data-qty-input aria-label="Quantity">
                <button type="button" class="pdp__qty-btn" data-qty-plus aria-label="Increase quantity">&plus;</button>
              </div>
              <button
                type="submit"
                class="pdp__add-to-cart"
                data-add-to-cart
                {% unless current_variant.available %}disabled{% endunless %}
              >
                {%- if current_variant.available -%}
                  {{ 'products.product.add_to_cart' | t }}
                {%- else -%}
                  {{ 'products.product.sold_out' | t }}
                {%- endif -%}
              </button>
            </div>
          </div>
        {%- endform -%}

        <div class="pdp__care-instructions">
          <h4 class="pdp__care-heading">Care Instructions</h4>
          <ul class="pdp__care-list">
            <li>Wash separately in cold water to preserve fabric quality and colour.</li>
            <li>Do not tumble dry; air dry in shade for best results. Always turn the garment inside-out to prevent fading.</li>
            <li>Colour and print may gradually fade over time with repeated washes.</li>
            <li>Each piece is handmade in small batches; slight variations and irregularities are a natural part of the garment's uniqueness.</li>
          </ul>
        </div>

      </div>
    </div>

  </div>
</div>

{%- comment -%} Related Products (same collection) {%- endcomment -%}
{%- assign related_collection = product.collections | first -%}
{%- if related_collection != blank and related_collection.products_count > 1 -%}
  <div class="pdp-related">
    <div class="container">
      <h2 class="pdp-related__heading">You May Also Like</h2>
      <div class="pdp-related__grid">
        {%- for item in related_collection.products limit: 5 -%}
          {%- unless item.id == product.id -%}
            {%- render 'product-card', product: item -%}
          {%- endunless -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .pdp {
    padding: 0 0 64px;
  }

  /* ── Related Products ── */
  .pdp-related {
    padding: 48px 0 64px;
  }

  .pdp-related__heading {
    font-family: 'Outfit', sans-serif;
    font-size: 28px;
    font-weight: 600;
    color: #313D65;
    margin: 0 0 24px;
  }

  .pdp-related__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  @media screen and (max-width: 989px) {
    .pdp-related__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .pdp-related__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .pdp-related__heading {
      font-size: 22px;
    }
  }


  /* ── Main: gallery + info ── */
  .pdp__main {
    display: grid;
    grid-template-columns: 600px 1fr;
    gap: 24px;
    margin-bottom: 48px;
  }

  /* ── Gallery ── */
  .pdp__gallery {
    display: flex;
    gap: 16px;
  }

  .pdp__thumbs {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-height: 512px;
    overflow-y: auto;
    scrollbar-width: none;
  }

  .pdp__thumbs::-webkit-scrollbar {
    display: none;
  }

  .pdp__thumb {
    width: 125px;
    height: 160px;
    flex-shrink: 0;
    overflow: hidden;
    border: none;
    padding: 0;
    cursor: pointer;
    opacity: 0.4;
    transition: opacity 0.2s ease;
    background: #f5f5f5;
  }

  .pdp__thumb--active {
    opacity: 1;
  }

  .pdp__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .pdp__main-image {
    flex: 1;
    overflow: hidden;
    background: #f5f5f5;
  }

  .pdp__main-image img,
  .pdp__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    max-height: 512px;
  }

  /* ── Product info ── */
  .pdp__info {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .pdp__title {
    font-family: 'Outfit', sans-serif;
    font-size: 32px;
    line-height: 1.2;
    color: #0C0C0C;
    font-weight: 700;
    margin: 0 0 12px;
  }

  .pdp__description {
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 1.6;
    color: #353535;
    margin: 0 0 20px;
  }

  .pdp__price {
    font-family: 'Outfit', sans-serif;
    font-size: 24px;
    font-weight: 700;
    color: #0C0C0C;
    margin: 0 0 24px;
  }

  .pdp__option-group {
    margin-bottom: 24px;
  }

  .pdp__label {
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: #0C0C0C;
    margin: 0 0 12px;
  }

  .pdp__label-value {
    font-weight: 400;
  }

  .pdp__color-swatches {
    display: flex;
    gap: 8px;
  }

  .pdp__swatch {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid transparent;
    cursor: pointer;
    padding: 0;
    transition: border-color 0.15s ease;
  }

  .pdp__swatch--selected {
    border-color: #0C0C0C;
  }

  .pdp__option-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .pdp__option-btn {
    min-width: 80px;
    height: 44px;
    padding: 0 20px;
    border: 1px solid #DFDFDF;
    background: #fff;
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #353535;
    cursor: pointer;
    border-radius: 4px;
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  .pdp__option-btn:hover {
    border-color: #0C0C0C;
  }

  .pdp__option-btn--selected {
    background: #F2E8E1;
    border-color: #F2E8E1;
    color: #0C0C0C;
    font-weight: 600;
  }

  /* ── Quantity + Add to cart row ── */
  .pdp__cart-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .pdp__qty {
    display: flex;
    align-items: center;
    border: 1px solid #DFDFDF;
    border-radius: 4px;
    overflow: hidden;
    height: 48px;
  }

  .pdp__qty-btn {
    width: 44px;
    height: 100%;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 18px;
    color: #353535;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s ease;
  }

  .pdp__qty-btn:hover {
    background: #f5f5f5;
  }

  .pdp__qty-input {
    width: 44px;
    height: 100%;
    border: none;
    text-align: center;
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: #0C0C0C;
    outline: none;
    -moz-appearance: textfield;
  }

  .pdp__qty-input::-webkit-inner-spin-button,
  .pdp__qty-input::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  /* ── Add to cart ── */
  .pdp__add-to-cart {
    flex: 1;
    height: 48px;
    background-color: #8FA1B7;
    border: none;
    border-radius: 4px;
    color: #fff;
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: 600;
    text-transform: capitalize;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .pdp__add-to-cart:hover {
    opacity: 0.9;
  }

  .pdp__add-to-cart:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* ── Care instructions ── */
  .pdp__care-instructions {
    margin-top: 24px;
  }

  .pdp__care-heading {
    font-family: 'Outfit', sans-serif;
    font-size: 18px;
    font-weight: 600;
    color: #313D65;
    margin: 0 0 12px;
  }

  .pdp__care-list {
    list-style: disc;
    padding-left: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .pdp__care-list li {
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    line-height: 1.6;
    color: #353535;
  }
  /* ── Tablet ── */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .pdp__main {
      grid-template-columns: 1fr 1fr;
    }

    .pdp__thumb {
      width: 80px;
      height: 100px;
    }

    .pdp__title {
      font-size: 26px;
    }
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    .pdp {
      padding-bottom: 40px;
    }

    .pdp__main {
      grid-template-columns: 1fr;
      gap: 24px;
      margin-bottom: 32px;
    }

    .pdp__gallery {
      flex-direction: column-reverse;
      gap: 12px;
    }

    .pdp__thumbs {
      flex-direction: row;
      max-height: none;
      overflow-x: auto;
      gap: 8px;
    }

    .pdp__thumb {
      width: 64px;
      height: 80px;
    }

    .pdp__main-image img,
    .pdp__image {
      max-height: 400px;
    }

    .pdp__title {
      font-size: 22px;
    }

    .pdp__description {
      font-size: 14px;
    }

  }
{% endstylesheet %}

{% javascript %}
(function() {
  'use strict';
  // Gallery thumbnails
  var thumbs = document.querySelectorAll('[data-gallery-thumb]');
  var mainImg = document.querySelector('[data-gallery-main] img');
  if (mainImg && thumbs.length) {
    for (var i = 0; i < thumbs.length; i++) {
      thumbs[i].addEventListener('click', function() {
        for (var j = 0; j < thumbs.length; j++) thumbs[j].classList.remove('pdp__thumb--active');
        this.classList.add('pdp__thumb--active');
        var srcset = this.getAttribute('data-image-srcset');
        var src = this.getAttribute('data-image-url');
        if (srcset) mainImg.setAttribute('srcset', srcset);
        if (src) mainImg.setAttribute('src', src);
      });
    }
  }

  // Variant selection
  var productJson = document.querySelector('[data-product-json]');
  if (!productJson) return;
  var productData = JSON.parse(productJson.textContent);
  var variantIdInput = document.querySelector('[data-variant-id]');
  var addToCartBtn = document.querySelector('[data-add-to-cart]');
  var priceEl = document.querySelector('[data-pdp-price]');
  var selectedOptions = productData.options.map(function(_, i) {
    return productData.selected_variant ? productData.selected_variant.options[i] : productData.variants[0].options[i];
  });

  // Color swatch clicks
  var colorBtns = document.querySelectorAll('.pdp__swatch');
  for (var c = 0; c < colorBtns.length; c++) {
    colorBtns[c].addEventListener('click', function() {
      var idx = parseInt(this.getAttribute('data-option-index'), 10);
      var val = this.getAttribute('data-option-value');
      selectedOptions[idx] = val;
      for (var s = 0; s < colorBtns.length; s++) colorBtns[s].classList.remove('pdp__swatch--selected');
      this.classList.add('pdp__swatch--selected');
      var colorLabel = document.querySelector('[data-color-label]');
      if (colorLabel) colorLabel.textContent = val;
      updateVariant();
    });
  }

  // Option button clicks (size, etc.)
  var optionBtns = document.querySelectorAll('.pdp__option-btn');
  for (var d = 0; d < optionBtns.length; d++) {
    optionBtns[d].addEventListener('click', function() {
      var idx = parseInt(this.getAttribute('data-option-index'), 10);
      var val = this.getAttribute('data-option-value');
      selectedOptions[idx] = val;
      var siblings = this.parentElement.querySelectorAll('.pdp__option-btn');
      for (var s = 0; s < siblings.length; s++) siblings[s].classList.remove('pdp__option-btn--selected');
      this.classList.add('pdp__option-btn--selected');
      var labelValue = this.closest('.pdp__option-group').querySelector('.pdp__label-value');
      if (labelValue) labelValue.textContent = val;
      updateVariant();
    });
  }

  // Quantity stepper
  var qtyInput = document.querySelector('[data-qty-input]');
  var minusBtn = document.querySelector('[data-qty-minus]');
  var plusBtn = document.querySelector('[data-qty-plus]');
  if (qtyInput && minusBtn && plusBtn) {
    minusBtn.addEventListener('click', function() {
      var val = parseInt(qtyInput.value, 10) || 1;
      if (val > 1) qtyInput.value = val - 1;
    });
    plusBtn.addEventListener('click', function() {
      var val = parseInt(qtyInput.value, 10) || 1;
      qtyInput.value = val + 1;
    });
  }

  function updateVariant() {
    var match = productData.variants.find(function(v) {
      return v.options.every(function(opt, i) {
        return opt === selectedOptions[i];
      });
    });
    if (match && variantIdInput) {
      variantIdInput.value = match.id;
      if (priceEl) priceEl.textContent = formatMoney(match.price);
      if (addToCartBtn) {
        addToCartBtn.disabled = !match.available;
        addToCartBtn.textContent = match.available ? 'Add To Cart' : 'Sold Out';
      }
      var url = new URL(window.location.href);
      url.searchParams.set('variant', match.id);
      window.history.replaceState({}, '', url.toString());
    }
  }

  function formatMoney(cents) {
    return Shopify.formatMoney ? Shopify.formatMoney(cents) : (cents / 100).toFixed(2);
  }
})();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.product.name",
  "class": "section-main-product",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_sticky_cart",
      "default": false,
      "label": "Enable sticky cart bar"
    }
  ],
  "blocks": [
    {
      "type": "accordion",
      "name": "Accordion",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Fabric & Care",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        }
      ]
    },
    {
      "type": "material_card",
      "name": "Material card",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Silk",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "tags",
          "default": "Quick Dry, Chemical Free, Machine Washable",
          "label": "Tags (comma-separated)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product page",
      "blocks": [
        { "type": "accordion", "settings": { "heading": "Fitting" } },
        { "type": "accordion", "settings": { "heading": "Fabric & Care" } },
        { "type": "accordion", "settings": { "heading": "Shipping And Return" } },
        { "type": "material_card", "settings": { "heading": "Silk", "tags": "Quick Dry, Chemical Free, Machine Washable" } }
      ]
    }
  ]
}
{% endschema %}
