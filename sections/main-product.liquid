    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .pdp__title {
    font-family: 'Outfit', sans-serif;
    font-size: 22px;
    line-height: 1.2;
    color: #0C0C0C;
    font-weight: 700;
    margin: 0 0 12px;

    @media screen and (min-width: 750px) {
      font-size: 26px;
    }

    @media screen and (min-width: 990px) {
      font-size: 32px;
    }
  }

  .pdp__description {
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.6;
    color: #353535;
    margin: 0 0 20px;

    @media screen and (min-width: 750px) {
      font-size: 16px;
    }
  }

  .pdp__description ul {
    list-style: disc;
    padding-left: 20px;
    margin: 12px 0;
  }

  .pdp__description ol {
    list-style: decimal;
    padding-left: 20px;
    margin: 12px 0;
  }

  .pdp__description li {
    margin-bottom: 6px;
    line-height: 1.6;
  }

  .pdp__description b,
  .pdp__description strong {
    font-weight: 600;
    color: #0C0C0C;
  }

  .pdp__description i,
  .pdp__description em {
    font-style: italic;
  }

  .pdp__description a {
    color: #8FA1B7;
    text-decoration: underline;
    transition: color 0.2s ease;
  }

  .pdp__description a:hover {
    color: #313D65;
  }

  .pdp__description p {
    margin: 0 0 12px;
  }

  .pdp__description p:last-child {
    margin-bottom: 0;
  }

  .pdp__price {
    font-family: 'Outfit', sans-serif;
    font-size: 24px;
    font-weight: 700;
    color: #0C0C0C;
    margin: 0 0 24px;
  }

  .pdp__option-group {
    margin-bottom: 24px;
  }

  .pdp__label {
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: #0C0C0C;
    margin: 0 0 12px;
  }

  .pdp__label-value {
    font-weight: 400;
  }

  .pdp__color-swatches {
    display: flex;
    gap: 8px;
  }

  .pdp__swatch {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid transparent;
    cursor: pointer;
    padding: 0;
    transition: border-color 0.15s ease;
  }

  .pdp__swatch--selected {
    border-color: #0C0C0C;
  }

  .pdp__option-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .pdp__option-btn {
    border: 1px solid #DFDFDF;
    background: #fff;
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #353535;
    cursor: pointer;
    border-radius: 4px;
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  /* .pdp__option-btn:hover {
    border-color: #0C0C0C;
  } */

  .pdp__option-btn--selected {
    background: #F2E8E1;
    border-color: #F2E8E1;
    color: #0C0C0C;
    font-weight: 600;
  }

  .pdp__option-btn--soldout {
    opacity: 0.4;
    cursor: not-allowed;
    text-decoration: line-through;
  }

  .pdp__swatch--soldout {
    opacity: 0.3;
    cursor: not-allowed;
  }

  /* ── Quantity + Add to cart row ── */
  .pdp__cart-row {
    display: flex;
    align-items: stretch;
    gap: 12px;
    height: 48px;
  }

  .pdp__qty {
    display: flex;
    align-items: center;
    border: 1px solid #DFDFDF;
    border-radius: 4px;
    overflow: hidden;
  }

  .pdp__qty-btn {
    width: 44px;
    height: 100%;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 18px;
    color: #353535;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s ease;
  }

  @media (hover: hover) {
    .pdp__qty-btn:hover {
      background: #f5f5f5;
    }
  }

  .pdp__qty-input {
    width: 44px;
    height: 100%;
    border: none;
    text-align: center;
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: #0C0C0C;
    outline: none;
    -moz-appearance: textfield;
  }

  .pdp__qty-input::-webkit-inner-spin-button,
  .pdp__qty-input::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .pdp__qty--disabled {
    opacity: 0.4;
    pointer-events: none;
  }

  /* ── Add to cart ── */
  .pdp__add-to-cart {
    flex: 1;
    background-color: #8FA1B7;
    border: none;
    border-radius: 4px;
    color: #fff;
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: 600;
    text-transform: capitalize;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .pdp__add-to-cart:hover {
    opacity: 0.9;
  }

  .pdp__add-to-cart:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* ── Care instructions ── */
  .pdp__care-instructions {
    margin-top: 24px;
  }

  .pdp__care-heading {
    font-family: 'Outfit', sans-serif;
    font-size: 18px;
    font-weight: 600;
    color: #313D65;
    margin: 0 0 12px;
  }

  .pdp__care-list {
    list-style: disc;
    padding-left: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .pdp__care-list li {
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    line-height: 1.6;
    color: #353535;
  }

  /* ── Size Guide ── */
  .pdp__size-guide {
    margin-top: 24px;
  }

  .pdp__size-guide-heading {
    font-family: 'Outfit', sans-serif;
    font-size: 18px;
    font-weight: 600;
    color: #313D65;
    margin: 0 0 12px;
  }

  .pdp__size-guide-subheading {
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    color: #0C0C0C;
    margin: 0 0 6px;
  }

  .pdp__size-guide-note {
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    color: #353535;
    line-height: 1.6;
    margin: 0 0 16px;
  }

  .pdp__size-guide-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .pdp__size-guide-table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    min-width: 300px;
  }

  .pdp__size-guide-table th,
  .pdp__size-guide-table td {
    border: 1px solid #DFDFDF;
    padding: 10px 16px;
    text-align: center;
  }

  .pdp__size-guide-table th {
    font-weight: 600;
    color: #0C0C0C;
    background: #f7f8fa;
  }

  .pdp__size-guide-table td {
    color: #353535;
    font-weight: 400;
  }

{% endstylesheet %}

<script>window.__moneyFormat = {{ shop.money_format | json }};</script>

{% javascript %}
(function() {
  'use strict';
  // Variant selection
  var productJson = document.querySelector('[data-product-json]');
  if (!productJson) return;
  var productData = JSON.parse(productJson.textContent);
  var inventoryJson = document.querySelector('[data-inventory-json]');
  var inventoryMap = inventoryJson ? JSON.parse(inventoryJson.textContent) : {};
  var variantIdInput = document.querySelector('[data-variant-id]');
  var addToCartBtn = document.querySelector('[data-add-to-cart]');
  var priceEl = document.querySelector('[data-pdp-price]');
  var selectedOptions = productData.options.map(function(_, i) {
    return productData.selected_variant ? productData.selected_variant.options[i] : productData.variants[0].options[i];
  });

  // Color swatch clicks
  var colorBtns = document.querySelectorAll('.pdp__swatch');
  for (var c = 0; c < colorBtns.length; c++) {
    colorBtns[c].addEventListener('click', function() {
      var idx = parseInt(this.getAttribute('data-option-index'), 10);
      var val = this.getAttribute('data-option-value');
      selectedOptions[idx] = val;
      for (var s = 0; s < colorBtns.length; s++) colorBtns[s].classList.remove('pdp__swatch--selected');
      this.classList.add('pdp__swatch--selected');
      var colorLabel = document.querySelector('[data-color-label]');
      if (colorLabel) colorLabel.textContent = val;
      updateVariant();
    });
  }

  // Option button clicks (size, etc.)
  var optionBtns = document.querySelectorAll('.pdp__option-btn');
  for (var d = 0; d < optionBtns.length; d++) {
    optionBtns[d].addEventListener('click', function() {
      var idx = parseInt(this.getAttribute('data-option-index'), 10);
      var val = this.getAttribute('data-option-value');
      selectedOptions[idx] = val;
      var siblings = this.parentElement.querySelectorAll('.pdp__option-btn');
      for (var s = 0; s < siblings.length; s++) siblings[s].classList.remove('pdp__option-btn--selected');
      this.classList.add('pdp__option-btn--selected');
      var labelValue = this.closest('.pdp__option-group').querySelector('.pdp__label-value');
      if (labelValue) labelValue.textContent = val;
      updateVariant();
    });
  }

  // Quantity stepper
  var qtyInput = document.querySelector('[data-qty-input]');
  var minusBtn = document.querySelector('[data-qty-minus]');
  var plusBtn = document.querySelector('[data-qty-plus]');
  if (qtyInput && minusBtn && plusBtn) {
    minusBtn.addEventListener('click', function() {
      var val = parseInt(qtyInput.value, 10) || 1;
      if (val > 1) qtyInput.value = val - 1;
    });
    plusBtn.addEventListener('click', function() {
      var val = parseInt(qtyInput.value, 10) || 1;
      var maxQty = parseInt(qtyInput.getAttribute('data-max-qty'), 10) || 99;
      if (val < maxQty) {
        qtyInput.value = val + 1;
      }
    });
  }

  function updateVariant() {
    var match = productData.variants.find(function(v) {
      return v.options.every(function(opt, i) {
        return opt === selectedOptions[i];
      });
    });
    if (match && variantIdInput) {
      variantIdInput.value = match.id;
      if (priceEl) priceEl.textContent = formatMoney(match.price);
      var url = new URL(window.location.href);
      url.searchParams.set('variant', match.id);
      window.history.replaceState({}, '', url.toString());
      applyStockState(match);
    }
  }

  function applyStockState(variant) {
    fetch('/cart.js')
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        var inCart = 0;
        for (var i = 0; i < cart.items.length; i++) {
          if (cart.items[i].variant_id === variant.id) {
            inCart = cart.items[i].quantity;
            break;
          }
        }
        var stock = inventoryMap[variant.id] || 99;
        var remaining = stock - inCart;
        var canAdd = variant.available && remaining > 0;

        if (addToCartBtn) {
          addToCartBtn.disabled = !canAdd;
          if (!variant.available) {
            addToCartBtn.textContent = 'Sold Out';
          } else if (remaining <= 0) {
            addToCartBtn.textContent = 'No More Stock';
          } else {
            addToCartBtn.textContent = 'Add To Cart';
          }
        }
        if (qtyInput) {
          var maxQty = Math.max(remaining, 1);
          qtyInput.setAttribute('data-max-qty', maxQty);
          qtyInput.setAttribute('max', maxQty);
          qtyInput.value = 1;
          qtyInput.disabled = !canAdd;
          if (minusBtn) minusBtn.disabled = !canAdd;
          if (plusBtn) plusBtn.disabled = !canAdd;
          var qtyWrap = qtyInput.closest('.pdp__qty');
          if (qtyWrap) qtyWrap.classList.toggle('pdp__qty--disabled', !canAdd);
        }
      });
  }

  // Check stock on page load
  function getCurrentVariant() {
    return productData.variants.find(function(v) {
      return v.options.every(function(opt, i) {
        return opt === selectedOptions[i];
      });
    });
  }

  var initialVariant = getCurrentVariant();
  if (initialVariant) applyStockState(initialVariant);

  // Re-check when cart changes (add/remove/update from drawer)
  document.addEventListener('cart:updated', function() {
    var v = getCurrentVariant();
    if (v) applyStockState(v);
  });

  function formatMoney(cents) {
    var amount = Math.round(cents / 100).toLocaleString('en-IN');
    var format = window.__moneyFormat || '{{amount}}';
    return format.replace(/\{\{\s*amount\s*\}\}/g, amount).replace(/\{\{\s*amount_with_comma_separator\s*\}\}/g, amount);
  }
})();
{% endjavascript %}

<script type="module">
  import PhotoSwipe from 'https://cdn.jsdelivr.net/npm/photoswipe@5.4.4/dist/photoswipe.esm.min.js';

  (function() {
    var triggers = document.querySelectorAll('[data-pswp-trigger]');
    var itemEls = document.querySelectorAll('[data-pswp-src]');
    if (!triggers.length || !itemEls.length) return;

    var items = [];
    itemEls.forEach(function(el) {
      items.push({
        src: el.getAttribute('data-pswp-src'),
        w: parseInt(el.getAttribute('data-pswp-width'), 10),
        h: parseInt(el.getAttribute('data-pswp-height'), 10)
      });
    });

    triggers.forEach(function(trigger) {
      trigger.addEventListener('click', function(e) {
        e.preventDefault();
        var index = parseInt(trigger.getAttribute('data-pswp-index') || '0', 10);
        var pswp = new PhotoSwipe({
          dataSource: items,
          index: index,
          bgOpacity: 0.9
        });
        pswp.init();
      });
    });
  })();
</script>

