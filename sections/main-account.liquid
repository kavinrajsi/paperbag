<div class="account-page">
  <div class="container">
    <div class="account-page__header">
      <h1 class="account-page__title">{{ 'customer.account.title' | t }}</h1>
      <a href="{{ routes.account_logout_url }}" class="account-page__logout">{{ 'customer.account.logout' | t }}</a>
    </div>

    <h2 class="account-page__section-title">{{ 'customer.account.orders' | t }}</h2>

    {%- if customer.orders.size > 0 -%}
      <div class="account-page__table-wrap">
        <table class="account-page__table">
          <thead>
            <tr>
              <th>{{ 'customer.order.title' | t }}</th>
              <th>{{ 'customer.order.date' | t }}</th>
              <th>{{ 'customer.order.payment_status' | t }}</th>
              <th>{{ 'customer.order.fulfillment_status' | t }}</th>
              <th class="text-right">{{ 'customer.order.total' | t }}</th>
            </tr>
          </thead>
          <tbody>
            {%- for order in customer.orders -%}
              <tr>
                <td><a href="{{ order.customer_url }}">{{ order.name }}</a></td>
                <td>{{ order.created_at | date: '%B %d, %Y' }}</td>
                <td>{{ order.financial_status_label }}</td>
                <td>{{ order.fulfillment_status_label }}</td>
                <td class="text-right">{{ order.total_price | money }}</td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>
      </div>
    {%- else -%}
      <p class="account-page__empty">{{ 'customer.account.no_orders' | t }}</p>
    {%- endif -%}

    <div style="margin-top: 32px;">
      <a href="{{ routes.account_addresses_url }}" class="account-page__addresses-btn">{{ 'customer.account.addresses' | t }}</a>
    </div>
  </div>
</div>

{% stylesheet %}
  .account-page { padding: 32px 0 64px; }
  .account-page__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
  .account-page__title { font-family: 'ITC Avant Garde Gothic Pro Demi', sans-serif; font-size: 32px; color: #313D65; font-weight: normal; margin: 0; }
  .account-page__logout { font-family: 'Outfit', sans-serif; font-size: 14px; font-weight: 600; color: #313D65; text-decoration: none; }
  .account-page__logout:hover { text-decoration: underline; }
  .account-page__section-title { font-family: 'ITC Avant Garde Gothic Pro Demi', sans-serif; font-size: 24px; color: #313D65; font-weight: normal; margin: 0 0 24px; }
  .account-page__table-wrap { overflow-x: auto; }
  .account-page__table { width: 100%; border-collapse: collapse; font-family: 'Outfit', sans-serif; font-size: 16px; color: #353535; }
  .account-page__table th { font-family: 'ITC Avant Garde Gothic Pro Demi', sans-serif; font-size: 14px; font-weight: normal; color: #313D65; text-transform: uppercase; letter-spacing: 0.05em; padding: 12px 0; border-bottom: 2px solid #DFDFDF; text-align: left; }
  .account-page__table td { padding: 16px 0; border-bottom: 1px solid #DFDFDF; }
  .account-page__table a { color: #313D65; text-decoration: none; }
  .account-page__table a:hover { text-decoration: underline; }
  .account-page__empty { font-family: 'Outfit', sans-serif; font-size: 16px; color: #ADADAD; }
  .account-page__addresses-btn { display: inline-flex; align-items: center; justify-content: center; height: 40px; padding: 0 24px; border: 1px solid #313D65; color: #313D65; font-family: 'Outfit', sans-serif; font-size: 14px; font-weight: 600; text-decoration: none; text-transform: capitalize; transition: background 0.2s, color 0.2s; }
  .account-page__addresses-btn:hover { background: #313D65; color: #fff; }
  @media (max-width: 749px) { .account-page__title { font-size: 22px; } .account-page__header { flex-direction: column; align-items: flex-start; gap: 12px; } .account-page__table { font-size: 14px; } }
{% endstylesheet %}

{% schema %}
{ "name": "Customer account", "settings": [] }
{% endschema %}
