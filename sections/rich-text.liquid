{%- liquid
  assign heading = section.settings.heading
  assign content = section.settings.content
  assign narrow_width = section.settings.narrow_width
-%}

<section class="rich-text" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="rich-text__inner{% if narrow_width %} rich-text__inner--narrow{% endif %}">
      {%- if heading != blank -%}
        <h2 class="rich-text__heading">{{ heading }}</h2>
      {%- endif -%}

      {%- if content != blank -%}
        <div class="rich-text__content rte">{{ content }}</div>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .rich-text {
    padding: 48px 0;
  }

  .rich-text__inner {
    text-align: center;
  }

  .rich-text__inner--narrow {
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .rich-text__heading {
    font-size: 2rem;
    margin-bottom: 16px;
  }

  .rich-text__content {
    line-height: 1.6;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.rich_text.name",
  "class": "section-rich-text",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.rich_text.settings.heading.label"
    },
    {
      "type": "richtext",
      "id": "content",
      "default": "<p>Use this text to share information about your brand with your customers. Describe a product, share announcements, or welcome customers to your store.</p>",
      "label": "t:sections.rich_text.settings.content.label"
    },
    {
      "type": "checkbox",
      "id": "narrow_width",
      "default": true,
      "label": "t:sections.rich_text.settings.narrow_width.label"
    }
  ],
  "presets": [
    {
      "name": "Rich text"
    }
  ]
}
{% endschema %}
