<div class="cart-pg">
  <div class="cart-pg__container">

    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post" class="cart-pg__form">
        {%- comment -%} Table header {%- endcomment -%}
        <div class="cart-pg__table-head">
          <span class="cart-pg__col cart-pg__col--product">Product</span>
          <span class="cart-pg__col cart-pg__col--price">Price</span>
          <span class="cart-pg__col cart-pg__col--qty">Quantity</span>
          <span class="cart-pg__col cart-pg__col--total">Total</span>
        </div>

        {%- comment -%} Cart items {%- endcomment -%}
        <div class="cart-pg__items">
          {%- for item in cart.items -%}
            <div class="cart-pg__item" data-cart-item data-key="{{ item.key }}">
              <div class="cart-pg__col cart-pg__col--product">
                <div class="cart-pg__product">
                  <a href="{{ item.url }}" class="cart-pg__item-image">
                    {%- if item.image -%}
                      <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" loading="lazy">
                    {%- endif -%}
                  </a>
                  <div class="cart-pg__item-info">
                    <h3 class="cart-pg__item-title">{{ item.product.title }}</h3>
                    {%- for option in item.options_with_values -%}
                      <p class="cart-pg__item-option">{{ option.name }}: {{ option.value }}</p>
                    {%- endfor -%}
                    <button type="button" class="cart-pg__item-remove" data-cart-remove aria-label="Remove">
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                    </button>
                  </div>
                </div>
              </div>
              <div class="cart-pg__col cart-pg__col--price">
                <span class="cart-pg__item-price">{{ item.original_price | money }}</span>
              </div>
              <div class="cart-pg__col cart-pg__col--qty">
                <div class="cart-pg__qty-control">
                  <button type="button" class="cart-pg__qty-btn" aria-label="Decrease" data-quantity-minus>&minus;</button>
                  <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" class="cart-pg__qty-input" aria-label="Quantity">
                  <button type="button" class="cart-pg__qty-btn" aria-label="Increase" data-quantity-plus>+</button>
                </div>
              </div>
              <div class="cart-pg__col cart-pg__col--total">
                <span class="cart-pg__line-total">{{ item.final_line_price | money }}</span>
              </div>
            </div>
          {%- endfor -%}
        </div>

        {%- comment -%} Footer: subtotal + checkout {%- endcomment -%}
        <div class="cart-pg__footer">
          <div class="cart-pg__subtotal">
            <span>Subtotal</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          <p class="cart-pg__taxes">Inclusive of all taxes and shipping</p>

          <button type="submit" name="checkout" class="cart-pg__checkout-btn">Check Out</button>
        </div>
      </form>
    {%- else -%}
      <div class="cart-pg__empty">
        <p class="cart-pg__empty-text">{{ 'cart.empty' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="cart-pg__empty-btn">Continue Shopping</a>
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .cart-pg {
    padding: 40px 0 80px;
  }

  .cart-pg__container {
    --bs-gutter-x: 1.5rem;
    width: 100%;
    padding-right: calc(var(--bs-gutter-x) * 0.5);
    padding-left: calc(var(--bs-gutter-x) * 0.5);
    margin-right: auto;
    margin-left: auto;
  }
  @media (min-width: 576px) { .cart-pg__container { max-width: 540px; } }
  @media (min-width: 768px) { .cart-pg__container { max-width: 720px; } }
  @media (min-width: 992px) { .cart-pg__container { max-width: 960px; } }
  @media (min-width: 1200px) { .cart-pg__container { max-width: 1140px; } }
  @media (min-width: 1400px) { .cart-pg__container { max-width: 1320px; } }

  /* ── Table header ── */
  .cart-pg__table-head {
    display: none;
    background: var(--color-brand);
    color: #faf8f3;
    padding: 12px 24px;
    border-radius: 6px;
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    font-weight: 600;
  }

  @media (min-width: 768px) {
    .cart-pg__table-head {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 16px;
    }
  }

  .cart-pg__col--price,
  .cart-pg__col--qty { text-align: center; }
  .cart-pg__col--total { text-align: right; }

  /* ── Cart items ── */
  .cart-pg__items {
    display: flex;
    flex-direction: column;
  }

  .cart-pg__item {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 24px 0;
    border-bottom: 1px solid var(--color-muted);
  }

  @media (min-width: 768px) {
    .cart-pg__item {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 16px;
      align-items: center;
      padding: 24px;
    }
  }

  /* ── Product column ── */
  .cart-pg__product {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .cart-pg__item-image {
    width: 80px;
    height: 80px;
    flex-shrink: 0;
    overflow: hidden;
    display: block;
    border-radius: 6px;
  }

  .cart-pg__item-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 0;
  }

  .cart-pg__item-info {
    flex: 1;
    min-width: 0;
  }

  .cart-pg__item-title {
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: var(--color-black);
    margin: 0 0 2px;
    line-height: 1.3;
  }

  .cart-pg__item-option {
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.5;
    text-transform: capitalize;
  }

  .cart-pg__item-remove {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: var(--color-text-muted);
    margin-top: 4px;
    transition: color 0.2s;
  }

  .cart-pg__item-remove:hover {
    color: var(--color-black);
  }

  /* ── Price column ── */
  .cart-pg__item-price {
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: var(--color-black);
  }

  /* ── Quantity column ── */
  .cart-pg__qty-control {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--color-muted);
    border-radius: 4px;
    overflow: hidden;
    height: 38px;
  }

  .cart-pg__qty-btn {
    width: 38px;
    height: 100%;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 16px;
    color: var(--color-black);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }

  .cart-pg__qty-btn:hover {
    background: var(--color-light);
  }

  .cart-pg__qty-input {
    width: 38px;
    height: 100%;
    text-align: center;
    border: none;
    border-left: 1px solid var(--color-muted);
    border-right: 1px solid var(--color-muted);
    background: none;
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-black);
    outline: none;
    -moz-appearance: textfield;
  }

  .cart-pg__qty-input::-webkit-inner-spin-button,
  .cart-pg__qty-input::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  /* ── Total column ── */
  .cart-pg__line-total {
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: var(--color-black);
  }

  /* ── Footer ── */
  .cart-pg__footer {
    max-width: 480px;
    margin-left: auto;
    padding-top: 32px;
  }

  /* ── Order notes ── */
  .cart-pg__notes {
    margin-bottom: 24px;
  }

  .cart-pg__notes-label {
    display: block;
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: var(--color-black);
    margin-bottom: 8px;
  }

  .cart-pg__notes-input {
    width: 100%;
    min-height: 80px;
    padding: 12px;
    border: 1px solid var(--color-muted);
    border-radius: 6px;
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    color: var(--color-black);
    resize: vertical;
    outline: none;
    background: #fff;
  }

  .cart-pg__notes-input:focus {
    border-color: var(--color-brand);
  }

  /* ── Subtotal ── */
  .cart-pg__subtotal {
    display: flex;
    justify-content: space-between;
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: var(--color-black);
    margin-bottom: 4px;
  }

  .cart-pg__taxes {
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    color: var(--color-text-muted);
    margin: 0 0 20px;
  }

  /* ── Checkout button ── */
  .cart-pg__checkout-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 14px;
    background: var(--color-brand);
    border: none;
    color: #faf8f3;
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: 400;
    border-radius: 8px;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .cart-pg__checkout-btn:hover {
    opacity: 0.9;
  }

  /* ── Empty cart ── */
  .cart-pg__empty {
    text-align: center;
    padding: 64px 0;
  }

  .cart-pg__empty-text {
    font-family: 'Outfit', sans-serif;
    font-size: 18px;
    color: var(--color-text-muted);
    margin: 0 0 24px;
  }

  .cart-pg__empty-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 40px;
    background: var(--color-brand);
    color: #faf8f3;
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: 400;
    text-decoration: none;
    border-radius: 8px;
    transition: opacity 0.2s;
  }

  .cart-pg__empty-btn:hover {
    opacity: 0.9;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 767px) {
    .cart-pg {
      padding: 24px 0 40px;
    }

    .cart-pg__col--price { display: none; }
    .cart-pg__col--total { display: block; }

    .cart-pg__item-image {
      width: 70px;
      height: 70px;
    }

    .cart-pg__footer {
      max-width: 100%;
    }
  }
{% endstylesheet %}

{% javascript %}
(function() {
  'use strict';

  // Quantity buttons
  document.addEventListener('click', function(e) {
    var minus = e.target.closest('[data-quantity-minus]');
    var plus = e.target.closest('[data-quantity-plus]');
    if (!minus && !plus) return;

    var row = (minus || plus).closest('.cart-pg__qty-control');
    if (!row) return;
    var input = row.querySelector('.cart-pg__qty-input');
    if (!input) return;

    var val = parseInt(input.value, 10);
    if (minus) input.value = Math.max(0, val - 1);
    if (plus) input.value = val + 1;

    input.closest('form').submit();
  });

  // Remove buttons
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('[data-cart-remove]');
    if (!btn) return;
    e.preventDefault();

    var item = btn.closest('[data-cart-item]');
    if (!item) return;
    var key = item.getAttribute('data-key');

    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: key, quantity: 0 })
    }).then(function() {
      window.location.reload();
    });
  });
})();
{% endjavascript %}

{% schema %}
{
  "name": "Cart page",
  "settings": []
}
{% endschema %}
