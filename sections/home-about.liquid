{%- liquid
  assign heading = section.settings.heading
  assign content = section.settings.content
  assign image = section.settings.image
  assign btn_label = section.settings.button_label
  assign btn_link = section.settings.button_link
  assign container_type = section.settings.container_type
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign bg_color = section.settings.bg_color
  assign heading_color = section.settings.heading_color
  assign text_color = section.settings.text_color
-%}

<section
  class="home-about"
  style="
    --ha-padding-top: {{ padding_top }}px;
    --ha-padding-bottom: {{ padding_bottom }}px;
    --ha-bg-color: {{ bg_color }};
    --ha-heading-color: {{ heading_color }};
    --ha-text-color: {{ text_color }};
  "
>
  <div class="home-about__wrapper home-about__wrapper--{{ container_type }}">
    <div class="home-about__grid">

      <div class="home-about__content">
        <div class="section-title__heading">
          {%- if heading != blank -%}
            <h2 class="section-title">{{ heading }}</h2>
          {%- endif -%}

          {%- if content != blank -%}
            <div class="section-content">{{ content }}</div>
          {%- endif -%}
        </div>

        {%- if btn_label != blank -%}
          <div class="home-about__btn">
            <a href="{{ btn_link }}" class="btn btn--primary">
              {{ btn_label }}
            </a>
          </div>
        {%- endif -%}
      </div>

      <div class="home-about__media">
        {%- if image -%}
          <img
            class="home-about__image"
            src="{{ image | image_url: width: 1000 }}"
            srcset="
              {{ image | image_url: width: 500 }} 500w,
              {{ image | image_url: width: 750 }} 750w,
              {{ image | image_url: width: 1000 }} 1000w
            "
            sizes="(min-width: 990px) 42vw, 65vw"
            alt="{{ image.alt | default: heading | escape }}"
            loading="lazy"
            width="{{ image.width }}"
            height="{{ image.height }}"
          >
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'home-about__placeholder' }}
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home about",
  "class": "section-home-about",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "At Paperbag, less is always more."
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>Our clothing is designed to move with you, light, breathable, and effortless. Every piece carries a sense of freedom and ease, made to elevate your everyday.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_type",
      "label": "Container type",
      "default": "container",
      "options": [
        { "value": "container", "label": "Container" },
        { "value": "container-fluid", "label": "Container fluid" }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 64,
      "unit": "px",
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 64,
      "unit": "px",
      "label": "Padding bottom"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#313d65"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#8fa1b7"
    }
  ],
  "presets": [
    {
      "name": "Home about"
    }
  ]
}
{% endschema %}
