<div class="password-page section-padding">
  <div class="container text-center" style="max-width: 500px;">
    {%- if settings.logo != blank -%}
      <img src="{{ settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" class="password-page__logo" width="200">
    {%- else -%}
      <h1 class="h2">{{ shop.name }}</h1>
    {%- endif -%}

    <h2 class="password-page__heading h1">{{ 'password.title' | t }}</h2>
    <p class="password-page__subtext">{{ 'password.subtext' | t }}</p>

    {% form 'customer' %}
      <input type="hidden" name="contact[tags]" value="prospect">
      <div class="password-page__form">
        <input type="email" name="contact[email]" placeholder="{{ 'password.email_placeholder' | t }}" required class="form__input">
        <button type="submit" class="btn btn--primary">{{ 'password.submit' | t }}</button>
      </div>
    {% endform %}

    <details class="password-page__login">
      <summary>{{ 'password.enter_password' | t }}</summary>
      {% form 'storefront_password' %}
        <div class="password-page__form">
          <input type="password" name="password" placeholder="{{ 'password.password_label' | t }}" class="form__input">
          <button type="submit" class="btn btn--secondary">{{ 'general.search' | t }}</button>
        </div>
      {% endform %}
    </details>
  </div>
</div>

{% schema %}
{ "name": "Password page", "settings": [] }
{% endschema %}
