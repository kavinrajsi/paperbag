<div class="password-pg">
  <div class="container" style="max-width: 500px; text-align: center; padding: 80px 20px;">
    {%- if settings.logo != blank -%}
      <img src="{{ settings.logo | image_url: width: 200 }}" alt="{{ shop.name | escape }}" width="200" style="margin-bottom: 32px;">
    {%- else -%}
      <p class="password-pg__brand">{{ shop.name }}</p>
    {%- endif -%}

    <h1 class="password-pg__title">{{ 'password.title' | t }}</h1>
    <p class="password-pg__text">{{ 'password.subtext' | t }}</p>

    {% form 'customer' %}
      <input type="hidden" name="contact[tags]" value="prospect">
      <div class="password-pg__form">
        <input type="email" name="contact[email]" placeholder="{{ 'password.email_placeholder' | t | default: 'Enter your email' }}" required class="auth-page__input">
        <button type="submit" class="auth-page__btn" style="margin-top: 12px;">{{ 'password.submit' | t | default: 'Notify Me' }}</button>
      </div>
    {% endform %}

    <details class="password-pg__login">
      <summary class="auth-page__link">{{ 'password.enter_password' | t | default: 'Enter using password' }}</summary>
      {% form 'storefront_password' %}
        <div class="password-pg__form" style="margin-top: 16px;">
          <input type="password" name="password" placeholder="{{ 'password.password_label' | t | default: 'Password' }}" class="auth-page__input">
          <button type="submit" class="auth-page__btn" style="margin-top: 12px;">{{ 'password.submit' | t | default: 'Enter' }}</button>
        </div>
      {% endform %}
    </details>
  </div>
</div>

{% stylesheet %}
  .password-pg__brand { font-family: 'Outfit', sans-serif; font-size: 48px; font-weight: 700; color: #313D65; margin: 0 0 32px; }
  .password-pg__title { font-family: 'ITC Avant Garde Gothic Pro Demi', sans-serif; font-size: 32px; color: #313D65; font-weight: normal; margin: 0 0 12px; }
  .password-pg__text { font-family: 'Outfit', sans-serif; font-size: 18px; color: #353535; margin: 0 0 32px; }
  .password-pg__form { max-width: 400px; margin: 0 auto; }
  .password-pg__login { margin-top: 32px; }
  .password-pg__login summary { cursor: pointer; list-style: none; }
  .password-pg__login summary::-webkit-details-marker { display: none; }
{% endstylesheet %}

{% schema %}
{ "name": "Password page", "settings": [] }
{% endschema %}
