{%- liquid
  assign collection = section.settings.collection
  assign products_count = section.settings.products_count
  assign title = section.settings.title
  assign show_title = section.settings.show_title
  assign container_type = section.settings.container_type
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign bg_color = section.settings.bg_color
  assign text_color = section.settings.text_color
  assign show_product_name = section.settings.show_product_name
  assign show_price = section.settings.show_price
  assign show_size = section.settings.show_size
  assign show_color = section.settings.show_color
  assign show_add_to_cart = section.settings.show_add_to_cart
  assign show_product_tag = section.settings.show_product_tag
  assign show_vendor = section.settings.show_vendor
  assign button_label = section.settings.button_label
-%}

{{ 'https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.css' | stylesheet_tag }}
{{ 'https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick-theme.min.css' | stylesheet_tag }}

{%- if collection != blank and collection.products.size > 0 -%}
  <section
    class="scroll-collection"
    style="
      --sc-padding-top: {{ padding_top }}px;
      --sc-padding-bottom: {{ padding_bottom }}px;
      --sc-bg-color: {{ bg_color }};
      --sc-text-color: {{ text_color }};
    "
    data-section-id="{{ section.id }}"
  >
    <div class="scroll-collection__wrapper scroll-collection__wrapper--{{ container_type }}">

      {%- if show_title and title != blank -%}
        <div class="scroll-collection__header">
          <h2 class="scroll-collection__title">{{ title }}</h2>
        </div>
      {%- endif -%}

      <div class="scroll-collection__slider" data-scroll-slider>
        <div class="scroll-collection__track" data-scroll-track>
          {%- for product in collection.products limit: products_count -%}
            {%- assign current_variant = product.selected_or_first_available_variant -%}
            <div
              class="scroll-collection__card"
              data-product-card
              data-variants="{{ product.variants | json | escape }}"
            >
              <a href="{{ product.url }}" class="scroll-collection__media">
                {%- if product.featured_image -%}
                  <img
                    class="scroll-collection__image"
                    src="{{ product.featured_image | image_url }}"
                    alt="{{ product.title | escape }}"
                    loading="lazy"
                  >
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'scroll-collection__placeholder' }}
                {%- endif -%}
              </a>

              <div class="scroll-collection__body">
                {%- if show_product_name or show_price -%}
                  <div class="scroll-collection__info">
                    {%- if show_product_name -%}
                      <p class="scroll-collection__name">
                        <a href="{{ product.url }}">{{ product.title }}</a>
                      </p>
                    {%- endif -%}
                    {%- if show_price -%}
                      <p class="scroll-collection__price" data-product-price>
                        {{ current_variant.price | money }}
                      </p>
                    {%- endif -%}
                  </div>
                {%- endif -%}

                {%- if show_vendor and product.vendor != blank -%}
                  <p class="scroll-collection__vendor">{{ product.vendor }}</p>
                {%- endif -%}

                {%- if show_product_tag and product.tags.size > 0 -%}
                  <span class="scroll-collection__tag">{{ product.tags | first }}</span>
                {%- endif -%}

                <form action="/cart/add" method="post">
                  <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>

                  {%- unless product.has_only_default_variant -%}
                    {%- if show_color -%}
                      {%- for option in product.options_with_values -%}
                        {%- assign option_name_down = option.name | downcase -%}
                        {%- if option_name_down == 'color' or option_name_down == 'colour' -%}
                          <div class="scroll-collection__option-group" data-option-index="{{ forloop.index0 }}">
                            <div class="scroll-collection__colors">
                              {%- for value in option.values -%}
                                <button
                                  type="button"
                                  class="scroll-collection__color-swatch{% if forloop.first %} scroll-collection__color-swatch--active{% endif %}"
                                  data-value="{{ value | escape }}"
                                  style="background-color: {{ value | downcase }};"
                                  title="{{ value }}"
                                >
                                  <span class="visually-hidden">{{ value }}</span>
                                </button>
                              {%- endfor -%}
                            </div>
                          </div>
                        {%- endif -%}
                      {%- endfor -%}
                    {%- endif -%}

                    {%- if show_size -%}
                      {%- for option in product.options_with_values -%}
                        {%- assign option_name_down = option.name | downcase -%}
                        {%- if option_name_down == 'size' or option_name_down == 'weight' -%}
                          <div class="scroll-collection__variants-row">
                            <div class="scroll-collection__option-group" data-option-index="{{ forloop.index0 }}">
                              <div class="scroll-collection__sizes">
                                {%- for value in option.values -%}
                                  <button
                                    type="button"
                                    class="scroll-collection__size-pill{% if forloop.first %} scroll-collection__size-pill--active{% endif %}"
                                    data-value="{{ value | escape }}"
                                  >
                                    {{ value }}
                                  </button>
                                {%- endfor -%}
                              </div>
                            </div>

                            {%- if show_add_to_cart -%}
                              <div class="scroll-collection__qty">
                                <button type="button" class="scroll-collection__qty-btn" data-qty-minus aria-label="Decrease quantity">&minus;</button>
                                <input
                                  type="number"
                                  name="quantity"
                                  value="1"
                                  min="1"
                                  class="scroll-collection__qty-input"
                                  data-qty-input
                                  aria-label="Quantity"
                                >
                                <button type="button" class="scroll-collection__qty-btn" data-qty-plus aria-label="Increase quantity">+</button>
                              </div>
                            {%- endif -%}
                          </div>
                        {%- endif -%}
                      {%- endfor -%}
                    {%- endif -%}
                  {%- endunless -%}

                  {%- if show_add_to_cart -%}
                    {%- comment -%} Show qty if no size option rendered it {%- endcomment -%}
                    {%- if product.has_only_default_variant or show_size == false -%}
                      <div class="scroll-collection__variants-row scroll-collection__variants-row--qty-only">
                        <div class="scroll-collection__qty">
                          <button type="button" class="scroll-collection__qty-btn" data-qty-minus aria-label="Decrease quantity">&minus;</button>
                          <input
                            type="number"
                            name="quantity"
                            value="1"
                            min="1"
                            class="scroll-collection__qty-input"
                            data-qty-input
                            aria-label="Quantity"
                          >
                          <button type="button" class="scroll-collection__qty-btn" data-qty-plus aria-label="Increase quantity">+</button>
                        </div>
                      </div>
                    {%- endif -%}

                    <button type="submit" class="scroll-collection__atc btn btn--primary">
                      {{ button_label }}
                    </button>
                  {%- endif -%}
                </form>
              </div>
            </div>
          {%- endfor -%}
        </div>

        <div class="scroll-collection__nav">
          <div class="scroll-collection__dots"></div>
          <div class="scroll-collection__arrows">
            <button class="scroll-collection__arrow scroll-collection__arrow--prev" type="button" aria-label="Previous slide">
              <svg width="19" height="13" viewBox="0 0 19 13" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M19 6.10761C19 5.92765 18.9285 5.75507 18.8013 5.62782C18.674 5.50057 18.5014 5.42908 18.3215 5.42908H2.31773L6.58844 1.15978C6.65153 1.0967 6.70155 1.0218 6.73565 0.939375C6.76979 0.856948 6.78737 0.768603 6.78737 0.679385C6.78737 0.590167 6.76979 0.501823 6.73565 0.419396C6.70155 0.336969 6.65153 0.262074 6.58844 0.198987C6.52535 0.1359 6.45045 0.0858575 6.36803 0.0517152C6.2856 0.0175729 6.19725 0 6.10804 0C6.01882 0 5.93047 0.0175729 5.84805 0.0517152C5.76562 0.0858575 5.69073 0.1359 5.62764 0.198987L0.199319 5.62721C0.136232 5.69024 0.0860478 5.76512 0.0518441 5.84755C0.0176404 5.92999 0 6.01836 0 6.10761C0 6.19686 0.0176404 6.28523 0.0518441 6.36767C0.0860478 6.4501 0.136232 6.52498 0.199319 6.58801L5.62764 12.0162C5.69073 12.0793 5.76562 12.1294 5.84805 12.1635C5.93047 12.1976 6.01882 12.2152 6.10804 12.2152C6.19725 12.2152 6.2856 12.1976 6.36803 12.1635C6.45045 12.1294 6.52535 12.0793 6.58844 12.0162C6.65153 11.9531 6.70155 11.8783 6.73565 11.7958C6.76979 11.7134 6.78737 11.6251 6.78737 11.5358C6.78737 11.4466 6.76979 11.3583 6.73565 11.2758C6.70155 11.1934 6.65153 11.1185 6.58844 11.0554L2.31773 6.78614H18.3215C18.5014 6.78614 18.674 6.71465 18.8013 6.5874C18.9285 6.46015 19 6.28757 19 6.10761Z" fill="#161A1D"/></svg>
            </button>
            <button class="scroll-collection__arrow scroll-collection__arrow--next" type="button" aria-label="Next slide">
              <svg width="19" height="13" viewBox="0 0 19 13" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M0 6.10761C0 5.92765 0.0714874 5.75507 0.198736 5.62782C0.325985 5.50057 0.498571 5.42908 0.678528 5.42908H16.6823L12.4116 1.15978C12.3485 1.0967 12.2985 1.0218 12.2644 0.939375C12.2302 0.856948 12.2126 0.768603 12.2126 0.679385C12.2126 0.590167 12.2302 0.501823 12.2644 0.419396C12.2985 0.336969 12.3485 0.262074 12.4116 0.198987C12.4747 0.1359 12.5496 0.0858575 12.632 0.0517152C12.7145 0.0175729 12.8028 0 12.892 0C12.9813 0 13.0696 0.0175729 13.152 0.0517152C13.2345 0.0858575 13.3093 0.1359 13.3724 0.198987L18.8007 5.62721C18.8638 5.69024 18.914 5.76512 18.9482 5.84755C18.9824 5.92999 19 6.01836 19 6.10761C19 6.19686 18.9824 6.28523 18.9482 6.36767C18.914 6.4501 18.8638 6.52498 18.8007 6.58801L13.3724 12.0162C13.3093 12.0793 13.2345 12.1294 13.152 12.1635C13.0696 12.1976 12.9813 12.2152 12.892 12.2152C12.8028 12.2152 12.7145 12.1976 12.632 12.1635C12.5496 12.1294 12.4747 12.0793 12.4116 12.0162C12.3485 11.9531 12.2985 11.8783 12.2644 11.7958C12.2302 11.7134 12.2126 11.6251 12.2126 11.5358C12.2126 11.4466 12.2302 11.3583 12.2644 11.2758C12.2985 11.1934 12.3485 11.1185 12.4116 11.0554L16.6823 6.78614H0.678528C0.498571 6.78614 0.325985 6.71465 0.198736 6.5874C0.0714874 6.46015 0 6.28757 0 6.10761Z" fill="#161A1D"/></svg>
            </button>
          </div>
        </div>
      </div>

    </div>
  </section>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.js" defer></script>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var section = document.querySelector('[data-section-id="{{ section.id }}"]');
      if (!section) return;

      /* ── Slick carousel ── */
      var $track = $(section).find('[data-scroll-track]');
      $track.slick({
        slidesToShow: 4,
        slidesToScroll: 1,
        arrows: true,
        prevArrow: $(section).find('.scroll-collection__arrow--prev'),
        nextArrow: $(section).find('.scroll-collection__arrow--next'),
        dots: true,
        appendDots: $(section).find('.scroll-collection__dots'),
        infinite: false,
        responsive: [
          {
            breakpoint: 992,
            settings: {
              slidesToShow: 3.5
            }
          },
          {
            breakpoint: 768,
            settings: {
              slidesToShow: 1.5
            }
          }
        ]
      });

      /* ── Product card interactions ── */
      section.querySelectorAll('[data-product-card]').forEach(function (card) {
        var variants = JSON.parse(card.dataset.variants);
        var variantInput = card.querySelector('[data-variant-id]');
        var priceEl = card.querySelector('[data-product-price]');

        /* Option selection */
        card.querySelectorAll('.scroll-collection__option-group').forEach(function (group) {
          var buttons = group.querySelectorAll('button');
          buttons.forEach(function (btn) {
            btn.addEventListener('click', function () {
              buttons.forEach(function (b) {
                b.className = b.className.replace(/\s*\S+--active/g, '');
              });
              btn.className += ' ' + btn.className.split(' ')[0] + '--active';
              findAndSetVariant();
            });
          });
        });

        function findAndSetVariant() {
          var selected = [];
          card.querySelectorAll('.scroll-collection__option-group').forEach(function (group) {
            var active = group.querySelector('[class*="--active"]');
            if (active) selected[parseInt(group.dataset.optionIndex)] = active.dataset.value;
          });

          var match = variants.find(function (v) {
            return selected.every(function (opt, i) {
              return v['option' + (i + 1)] === opt;
            });
          });

          if (match && variantInput) {
            variantInput.value = match.id;
            if (priceEl) {
              var formatted = Shopify.formatMoney ? Shopify.formatMoney(match.price) : ('$' + (match.price / 100).toFixed(2));
              priceEl.innerHTML = formatted;
            }
          }
        }

        /* Quantity stepper */
        var qtyInput = card.querySelector('[data-qty-input]');
        var minusBtn = card.querySelector('[data-qty-minus]');
        var plusBtn = card.querySelector('[data-qty-plus]');

        if (minusBtn && qtyInput) {
          minusBtn.addEventListener('click', function () {
            var val = parseInt(qtyInput.value, 10);
            if (val > 1) qtyInput.value = val - 1;
          });
        }
        if (plusBtn && qtyInput) {
          plusBtn.addEventListener('click', function () {
            qtyInput.value = parseInt(qtyInput.value, 10) + 1;
          });
        }
      });
    });
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Scroll collection",
  "class": "section-scroll-collection",
  "settings": [
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "min": 4,
      "max": 24,
      "step": 1,
      "default": 8,
      "label": "Products to show"
    },
    {
      "type": "header",
      "content": "Section title"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show title",
      "default": true
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Scroll Collection"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_type",
      "label": "Container type",
      "default": "container",
      "options": [
        { "value": "container", "label": "Container" },
        { "value": "container-fluid", "label": "Container fluid" }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 56,
      "unit": "px",
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 56,
      "unit": "px",
      "label": "Padding bottom"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1816"
    },
    {
      "type": "header",
      "content": "Product card toggles"
    },
    {
      "type": "checkbox",
      "id": "show_product_name",
      "label": "Show product name",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_size",
      "label": "Show size options",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_color",
      "label": "Show color swatches",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_add_to_cart",
      "label": "Show add to cart",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product_tag",
      "label": "Show product tag",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor name",
      "default": false
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Add to cart"
    }
  ],
  "presets": [
    {
      "name": "Scroll collection"
    }
  ]
}
{% endschema %}
