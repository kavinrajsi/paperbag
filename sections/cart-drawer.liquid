<div class="cart-drawer" data-cart-drawer aria-hidden="true">
  <div class="cart-drawer__overlay" data-cart-drawer-overlay></div>
  <div class="cart-drawer__content">
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title">Shopping Cart</h2>
      <button class="cart-drawer__close" data-cart-drawer-close aria-label="Close">
        {% render 'icon', icon: 'close' %}
      </button>
    </div>

    <div class="cart-drawer__body">
      <div class="cart-drawer__items" data-cart-items>
        {%- if cart.item_count > 0 -%}
          {%- for item in cart.items -%}
            <div class="cart-drawer__item" data-cart-item data-key="{{ item.key }}" data-max-qty="{{ item.variant.inventory_quantity | default: 99 }}">
              <a href="{{ item.url }}" class="cart-drawer__item-image">
                {%- if item.image -%}
                  <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" loading="lazy">
                {%- endif -%}
              </a>
              <div class="cart-drawer__item-details">
                <a href="{{ item.url }}" class="cart-drawer__item-title">{{ item.product.title }}</a>
                {%- for option in item.options_with_values -%}
                  <p class="cart-drawer__item-option">{{ option.name }}: {{ option.value }}</p>
                {%- endfor -%}
                <span class="cart-drawer__item-price">{{ item.final_line_price | money_without_trailing_zeros }}</span>
                <div class="cart-drawer__item-actions">
                  <div class="cart-drawer__qty">
                    <button class="cart-drawer__qty-btn" data-quantity-minus aria-label="Decrease">&minus;</button>
                    <input class="cart-drawer__qty-input" type="number" value="{{ item.quantity }}" min="1" data-quantity-input aria-label="Quantity">
                    <button class="cart-drawer__qty-btn" data-quantity-plus aria-label="Increase">+</button>
                  </div>
                  <button class="cart-drawer__item-remove" data-cart-remove aria-label="Remove">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                  </button>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- else -%}
          <div class="cart-drawer__empty">
            <p>{{ 'cart.empty' | t }}</p>
            <a href="{{ routes.all_products_collection_url }}" class="cart-drawer__shop-btn">{{ 'general.continue_shopping' | t }}</a>
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- if cart.item_count > 0 -%}
      <div class="cart-drawer__footer" data-cart-footer>
        <div class="cart-drawer__subtotal">
          <span>Subtotal</span>
          <span data-cart-subtotal>{{ cart.total_price | money_without_trailing_zeros }}</span>
        </div>
        <a href="/checkout" class="cart-drawer__checkout-btn">Check Out</a>
        <a href="{{ routes.cart_url }}" class="cart-drawer__viewcart-btn">View Cart</a>
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  /* ── Drawer shell ── */
  .cart-drawer { position: fixed; inset: 0; z-index: 200; visibility: hidden; transition: visibility 0.3s; }
  .cart-drawer.is-open { visibility: visible; }
  .cart-drawer__overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.4); opacity: 0; transition: opacity 0.3s; }
  .cart-drawer.is-open .cart-drawer__overlay { opacity: 1; }
  .cart-drawer__content { position: absolute; top: 0; right: 0; bottom: 0; width: 100%; max-width: 420px; background: #fff; transform: translateX(100%); transition: transform 0.3s ease; display: flex; flex-direction: column; }
  .cart-drawer.is-open .cart-drawer__content { transform: translateX(0); }

  /* ── Header ── */
  .cart-drawer__header { display: flex; justify-content: space-between; align-items: center; padding: 20px 24px; }
  .cart-drawer__title { font-family: 'Outfit', sans-serif; font-size: 22px; font-weight: 400; color: var(--color-brand); margin: 0; }
  .cart-drawer__close { background: none; border: none; padding: 0; cursor: pointer; color: var(--color-black); display: flex; }

  /* ── Body (scrollable) ── */
  .cart-drawer__body { flex: 1; overflow-y: auto; }
  .cart-drawer__items { padding: 0 24px 24px; }

  /* ── Cart item ── */
  .cart-drawer__item { display: flex; gap: 16px; padding: 24px 0; border-bottom: 1px solid var(--color-muted); }
  .cart-drawer__item:first-child { padding-top: 0; }
  .cart-drawer__item:last-child { border-bottom: none; }
  .cart-drawer__item-image { flex-shrink: 0; width: 120px; aspect-ratio: 4/5; border-radius: 6px; overflow: hidden; }
  .cart-drawer__item-image img { width: 100%; height: 100%; object-fit: cover; display: block; border-radius: 0; }
  .cart-drawer__item-details { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 2px; }
  .cart-drawer__item-title { font-family: 'Outfit', sans-serif; font-size: 16px; font-weight: 700; color: var(--color-black); text-decoration: none; display: block; }
  .cart-drawer__item-title:hover { text-decoration: underline; }
  .cart-drawer__item-option { font-family: 'Outfit', sans-serif; font-size: 14px; color: var(--color-text-secondary); margin: 0; line-height: 1.5; text-transform: capitalize; }

  /* ── Item actions (qty + trash + price) ── */
  .cart-drawer__item-actions { display: flex; align-items: center; gap: 12px; margin-top: auto; }
  .cart-drawer__qty { display: inline-flex; align-items: center; border: 1px solid var(--color-muted); border-radius: 4px; }
  .cart-drawer__qty-btn { background: none; border: none; padding: 10px 14px; cursor: pointer; color: var(--color-black); display: flex; align-items: center; font-size: 16px; line-height: 1; }
  .cart-drawer__qty-input { width: 32px; text-align: center; border: none; border-left: 1px solid var(--color-muted); border-right: 1px solid var(--color-muted); background: none; font-family: 'Outfit', sans-serif; font-size: 14px; color: var(--color-black); outline: none; -moz-appearance: textfield; padding: 10px 0; }
  .cart-drawer__qty-input::-webkit-inner-spin-button, .cart-drawer__qty-input::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
  .cart-drawer__item-price { font-family: 'Outfit', sans-serif; font-size: 15px; font-weight: 400; color: var(--color-black); margin: 4px 0 0; }
  .cart-drawer__item-remove { background: none; border: none; padding: 0; cursor: pointer; color: var(--color-text-muted); display: flex; align-items: center; transition: color 0.2s; margin-left: auto; }
  .cart-drawer__item-remove:hover { color: var(--color-black); }

  /* ── Empty state ── */
  .cart-drawer__empty { text-align: center; padding: 48px 0; font-family: 'Outfit', sans-serif; font-size: 16px; color: var(--color-text-muted); }
  .cart-drawer__empty p { margin-bottom: 16px; }
  .cart-drawer__shop-btn { display: inline-flex; align-items: center; justify-content: center; padding: 12px 40px; background: var(--color-brand); color: #faf8f3; font-family: 'Outfit', sans-serif; font-size: 16px; font-weight: 400; text-decoration: none; border-radius: 6px; transition: opacity 0.2s; }
  .cart-drawer__shop-btn:hover { opacity: 0.9; }

  /* ── Footer ── */
  .cart-drawer__footer { padding: 24px; border-top: 1px solid var(--color-muted); background: var(--color-off-white); }

  /* ── Order notes ── */
  .cart-drawer__notes { margin-bottom: 16px; }
  .cart-drawer__notes-toggle { display: flex; justify-content: space-between; align-items: center; width: 100%; background: none; border: none; padding: 0; cursor: pointer; font-family: 'Outfit', sans-serif; font-size: 15px; font-weight: 700; color: var(--color-black); }
  .cart-drawer__notes-toggle svg { transition: transform 0.2s ease; }
  .cart-drawer__notes-toggle[aria-expanded="true"] svg { transform: rotate(180deg); }
  .cart-drawer__notes-field { margin-top: 12px; }
  .cart-drawer__notes-input { width: 100%; min-height: 80px; padding: 12px; border: 1px solid var(--color-muted); border-radius: 6px; font-family: 'Outfit', sans-serif; font-size: 14px; color: var(--color-black); resize: vertical; outline: none; }
  .cart-drawer__notes-input:focus { border-color: var(--color-brand); }

  /* ── Subtotal ── */
  .cart-drawer__subtotal { display: flex; justify-content: space-between; font-family: 'Outfit', sans-serif; font-size: 16px; font-weight: 700; color: var(--color-black); margin-bottom: 16px; }

  /* ── Checkout button ── */
  .cart-drawer__checkout-btn { display: flex; align-items: center; justify-content: center; width: 100%; padding: 14px; background: var(--color-brand); color: #faf8f3; font-family: 'Outfit', sans-serif; font-size: 16px; font-weight: 400; text-decoration: none; border-radius: 8px; transition: opacity 0.2s; }
  .cart-drawer__checkout-btn:hover { opacity: 0.9; }

  /* ── View cart link ── */
  .cart-drawer__viewcart-btn { display: block; text-align: center; margin-top: 12px; font-family: 'Outfit', sans-serif; font-size: 14px; font-weight: 400; color: var(--color-black); text-decoration: none; }
  .cart-drawer__viewcart-btn:hover { text-decoration: underline; }
{% endstylesheet %}

{% schema %}
{ "name": "Cart drawer", "limit": 1 }
{% endschema %}
