<div class="page-404">
  <div class="container" style="text-align: center; padding: 80px 20px;">
    <h1 class="page-404__title">404</h1>
    <p class="page-404__subtitle">{{ '404.title' | t }}</p>
    <p class="page-404__text">{{ '404.subtext' | t }}</p>
    <form action="{{ routes.search_url }}" method="get" class="page-404__search">
      <div class="page-404__search-wrap">
        {%- render 'icon', icon: 'search' -%}
        <input type="search" name="q" placeholder="{{ 'search.placeholder' | t }}" class="page-404__search-input">
      </div>
    </form>
    <a href="{{ routes.root_url }}" class="page-404__btn">{{ 'general.continue_shopping' | t | default: 'Back to Home' }}</a>
  </div>
</div>

{% stylesheet %}
  .page-404 { padding: 64px 0; }
  .page-404__title { font-family: 'Outfit', sans-serif; font-size: 96px; color: #8FA1B7; font-weight: normal; margin: 0 0 8px; line-height: 1; }
  .page-404__subtitle { font-family: 'Outfit', sans-serif; font-size: 32px; color: #313D65; font-weight: normal; margin: 0 0 12px; }
  .page-404__text { font-family: 'Outfit', sans-serif; font-size: 18px; color: #353535; margin: 0 0 32px; }
  .page-404__search { max-width: 500px; margin: 0 auto 32px; }
  .page-404__search-wrap { display: flex; align-items: center; gap: 12px; border-bottom: 1px solid #ADADAD; padding-bottom: 8px; }
  .page-404__search-wrap .icon { color: #ADADAD; flex-shrink: 0; }
  .page-404__search-input { flex: 1; border: none; outline: none; background: none; font-family: 'Outfit', sans-serif; font-size: 18px; color: #0C0C0C; }
  .page-404__search-input::placeholder { color: #ADADAD; }
  .page-404__btn { display: inline-flex; align-items: center; justify-content: center; height: 40px; padding: 0 32px; background: #8FA1B7; color: #fff; font-family: 'Outfit', sans-serif; font-size: 14px; font-weight: 600; text-decoration: none; text-transform: capitalize; transition: opacity 0.2s; }
  .page-404__btn:hover { opacity: 0.9; }
  @media (max-width: 749px) { .page-404__title { font-size: 64px; } .page-404__subtitle { font-size: 22px; } .page-404__text { font-size: 14px; } }
{% endstylesheet %}

{% schema %}
{ "name": "404 page", "settings": [] }
{% endschema %}
