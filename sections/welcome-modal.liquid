{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign question = section.settings.question
  assign button_label = section.settings.button_label
  assign button_link = section.settings.button_link
  assign enable_modal = section.settings.enable_modal
-%}

{%- if enable_modal -%}
<div class="welcome-modal" data-welcome-modal aria-hidden="true">
  <div class="welcome-modal__backdrop" data-welcome-modal-close></div>

  <div class="welcome-modal__dialog" role="dialog" aria-modal="true" aria-label="{{ heading | escape }}">
    <button type="button" class="welcome-modal__close" data-welcome-modal-close aria-label="{{ 'general.close' | t }}">
      {%- render 'icon', icon: 'close' -%}
    </button>

    <div class="welcome-modal__content">
      {%- if heading != blank -%}
        <h2 class="welcome-modal__heading">{{ heading }}</h2>
      {%- endif -%}

      {%- if subheading != blank -%}
        <p class="welcome-modal__subheading">{{ subheading }}</p>
      {%- endif -%}

      {%- if question != blank -%}
        <p class="welcome-modal__question">{{ question }}</p>
      {%- endif -%}

      {%- if button_label != blank -%}
        <a href="{{ button_link | default: '#' }}" class="welcome-modal__btn" data-welcome-modal-close>
          {{ button_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  (function() {
    var STORAGE_KEY = 'paperbag_welcome_seen';
    var modal = document.querySelector('[data-welcome-modal]');
    if (!modal) return;

    if (sessionStorage.getItem(STORAGE_KEY)) return;

    function open() {
      modal.classList.add('welcome-modal--open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      modal.classList.remove('welcome-modal--open');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      sessionStorage.setItem(STORAGE_KEY, '1');
    }

    var closeBtns = modal.querySelectorAll('[data-welcome-modal-close]');
    for (var i = 0; i < closeBtns.length; i++) {
      closeBtns[i].addEventListener('click', function(e) {
        if (this.tagName === 'A') return;
        e.preventDefault();
        close();
      });
    }

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal.classList.contains('welcome-modal--open')) close();
    });

    setTimeout(open, {{ section.settings.delay | default: 1000 }});
  })();
</script>
{%- endif -%}

{% stylesheet %}
  .welcome-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s;
  }

  .welcome-modal--open {
    opacity: 1;
    visibility: visible;
  }

  .welcome-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(52, 49, 49, 0.6);
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
  }

  .welcome-modal__dialog {
    position: relative;
    background: #fff;
    width: 854px;
    max-width: calc(100vw - 40px);
    padding: 32px 24px;
    display: flex;
    align-items: flex-start;
    overflow: hidden;
    transform: translateY(16px);
    transition: transform 0.3s ease;
  }

  .welcome-modal--open .welcome-modal__dialog {
    transform: translateY(0);
  }

  .welcome-modal__close {
    position: absolute;
    top: 12px;
    right: 12px;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: #0C0C0C;
    transition: opacity 0.2s ease;
    z-index: 1;
  }

  .welcome-modal__close:hover {
    opacity: 0.6;
  }

  .welcome-modal__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 32px;
    min-height: 380px;
  }

  .welcome-modal__heading {
    font-family: 'Outfit', sans-serif;
    font-size: 32px;
    line-height: 1.2;
    color: #313D65;
    font-weight: normal;
    font-style: normal;
    margin: 0;
  }

  .welcome-modal__subheading {
    font-family: 'Gill Sans MT', 'Gill Sans', 'Calibri', sans-serif;
    font-size: 32px;
    font-weight: 400;
    font-style: italic;
    line-height: 1.8;
    color: #8FA1B7;
    text-transform: capitalize;
    margin: -16px 0 0;
  }

  .welcome-modal__question {
    font-family: 'Outfit', sans-serif;
    font-size: 30px;
    line-height: 1.2;
    color: #313D65;
    font-weight: normal;
    font-style: normal;
    margin: 0;
  }

  .welcome-modal__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 370px;
    max-width: 100%;
    height: 43px;
    background-color: #8FA1B7;
    color: #fff;
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 600;
    text-transform: capitalize;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .welcome-modal__btn:hover {
    opacity: 0.9;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    .welcome-modal__dialog {
      width: 318px;
      flex-direction: column;
      padding: 8px 16px 24px;
    }

    .welcome-modal__close {
      margin-bottom: 8px;
    }

    .welcome-modal__content {
      min-height: auto;
      gap: 20px;
    }

    .welcome-modal__heading {
      font-size: 20px;
      line-height: 1.4;
    }

    .welcome-modal__subheading {
      font-size: 16px;
      line-height: 1.4;
      margin-top: -8px;
    }

    .welcome-modal__question {
      font-size: 16px;
      line-height: 1.4;
    }

    .welcome-modal__btn {
      width: 100%;
      height: 40px;
    }
  }

  /* ── Tablet ── */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .welcome-modal__dialog {
      width: 640px;
    }

    .welcome-modal__content {
      min-height: 320px;
    }

    .welcome-modal__heading {
      font-size: 28px;
    }

    .welcome-modal__subheading {
      font-size: 26px;
    }

    .welcome-modal__question {
      font-size: 24px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Welcome modal",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_modal",
      "default": true,
      "label": "Enable welcome modal"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "Welcome to Paperbag",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "default": "Elegance in simplicity, Earth's harmony",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "question",
      "default": "Is it your first experience on Paperbag?",
      "label": "Question text"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "Create Your Own Style",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "delay",
      "min": 500,
      "max": 5000,
      "step": 500,
      "default": 1000,
      "unit": "ms",
      "label": "Delay before showing"
    }
  ],
  "presets": [
    {
      "name": "Welcome modal"
    }
  ]
}
{% endschema %}
