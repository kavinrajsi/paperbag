<div class="policy-page">
  <div class="container">

    <div class="policy-page__header">
      <h1 class="policy-page__title">{{ page.title }}</h1>
      {%- if section.settings.last_updated != blank -%}
        <p class="policy-page__updated">Last updated: {{ section.settings.last_updated }}</p>
      {%- endif -%}
    </div>

    <div class="policy-page__layout">
      {%- comment -%} Sidebar nav {%- endcomment -%}
      {%- if section.blocks.size > 0 -%}
        <nav class="policy-page__nav" aria-label="Policy sections">
          <ul class="policy-page__nav-list">
            {%- for block in section.blocks -%}
              <li>
                <a href="#policy-{{ forloop.index }}" class="policy-page__nav-link">{{ block.settings.heading }}</a>
              </li>
            {%- endfor -%}
          </ul>
        </nav>
      {%- endif -%}

      {%- comment -%} Content {%- endcomment -%}
      <div class="policy-page__content">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            <div class="policy-page__section" id="policy-{{ forloop.index }}" {{ block.shopify_attributes }}>
              <h2 class="policy-page__section-heading">{{ block.settings.heading }}</h2>
              <div class="policy-page__section-body rte">{{ block.settings.content }}</div>
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- comment -%} Fallback to CMS page content {%- endcomment -%}
          <div class="policy-page__section-body rte">{{ page.content }}</div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .policy-page { padding: 32px 0 64px; }

  .policy-page__header { margin-bottom: 40px; text-align: center; }
  .policy-page__title { font-family: 'Outfit', sans-serif; font-size: 32px; color: #313D65; font-weight: normal; margin: 0 0 8px; }
  .policy-page__updated { font-family: 'Outfit', sans-serif; font-size: 14px; color: #ADADAD; margin: 0; }

  .policy-page__layout { display: grid; grid-template-columns: 240px 1fr; gap: 48px; align-items: start; }

  /* Sidebar nav */
  .policy-page__nav { position: sticky; top: 120px; }
  .policy-page__nav-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px; }
  .policy-page__nav-link { display: block; padding: 8px 16px; font-family: 'Outfit', sans-serif; font-size: 16px; color: #353535; text-decoration: none; border-left: 2px solid transparent; transition: all 0.2s ease; }
  .policy-page__nav-link:hover { color: #313D65; border-left-color: #8FA1B7; background: #F2F4F6; }

  /* Content */
  .policy-page__section { margin-bottom: 40px; }
  .policy-page__section:last-child { margin-bottom: 0; }
  .policy-page__section-heading { font-family: 'Outfit', sans-serif; font-size: 24px; color: #313D65; font-weight: normal; margin: 0 0 16px; padding-bottom: 12px; border-bottom: 1px solid #DFDFDF; }
  .policy-page__section-body { font-family: 'Outfit', sans-serif; font-size: 18px; line-height: 1.8; color: #353535; }
  .policy-page__section-body p { margin: 0 0 16px; }
  .policy-page__section-body ul, .policy-page__section-body ol { padding-left: 24px; margin: 0 0 16px; }
  .policy-page__section-body li { margin-bottom: 8px; }
  .policy-page__section-body h3 { font-family: 'Outfit', sans-serif; font-size: 20px; color: #313D65; font-weight: normal; margin: 24px 0 12px; }
  .policy-page__section-body a { color: #313D65; }

  @media (max-width: 989px) {
    .policy-page__layout { grid-template-columns: 1fr; gap: 24px; }
    .policy-page__nav { position: static; border-bottom: 1px solid #DFDFDF; padding-bottom: 16px; }
    .policy-page__nav-list { flex-direction: row; flex-wrap: wrap; gap: 0; }
    .policy-page__nav-link { border-left: none; border-bottom: 2px solid transparent; padding: 8px 12px; font-size: 14px; }
    .policy-page__nav-link:hover { border-left: none; border-bottom-color: #8FA1B7; }
  }

  @media (max-width: 749px) {
    .policy-page__title { font-size: 22px; }
    .policy-page__section-heading { font-size: 20px; }
    .policy-page__section-body { font-size: 14px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Policy page",
  "settings": [
    { "type": "text", "id": "last_updated", "label": "Last updated date", "default": "March 2025" }
  ],
  "blocks": [
    {
      "type": "section",
      "name": "Policy section",
      "settings": [
        { "type": "text", "id": "heading", "label": "Section heading", "default": "Overview" },
        { "type": "richtext", "id": "content", "label": "Section content" }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "Policy page",
      "blocks": [
        { "type": "section", "settings": { "heading": "Overview" } },
        { "type": "section", "settings": { "heading": "Shipping Policy" } },
        { "type": "section", "settings": { "heading": "Returns & Exchanges" } },
        { "type": "section", "settings": { "heading": "Privacy Policy" } },
        { "type": "section", "settings": { "heading": "Terms of Service" } }
      ]
    }
  ]
}
{% endschema %}
