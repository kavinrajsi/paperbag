<div
  class="hero hero--{{ section.settings.height }}"
  data-hero
  data-autoplay-speed="{{ section.settings.autoplay_speed }}"
  style="--section-padding: {{ section.settings.padding }}px;"
>
  <div class="hero__slides" data-hero-slides>
    {%- for block in section.blocks -%}
      <div class="hero__slide{% if forloop.first %} hero__slide--active{% endif %}" data-hero-slide {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <div class="hero__image">
            {%- render 'image', image: block.settings.image, widths: '750,1000,1500,2000', sizes: '100vw', lazy: false -%}
          </div>
        {%- else -%}
          <div class="hero__image hero__image--placeholder">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}

        <div class="hero__overlay" style="opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};"></div>

        <div class="hero__content hero__content--{{ block.settings.text_alignment }}">
          <div class="hero__content-inner">
            {%- if block.settings.heading != blank -%}
              <h2 class="hero__heading">{{ block.settings.heading }}</h2>
            {%- endif -%}
            {%- if block.settings.subheading != blank -%}
              <p class="hero__subheading">{{ block.settings.subheading }}</p>
            {%- endif -%}
            {%- if block.settings.button_label != blank -%}
              <a href="{{ block.settings.button_link }}" class="hero__button">
                {{ block.settings.button_label }}
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <div class="hero__controls">
      <button class="hero__control hero__control--prev" data-hero-prev aria-label="{{ 'accessibility.previous_slide' | t }}">
        {%- render 'icon', icon: 'chevron-left' -%}
      </button>
      <div class="hero__dots" data-hero-dots>
        {%- for block in section.blocks -%}
          <button class="hero__dot{% if forloop.first %} hero__dot--active{% endif %}" data-hero-dot="{{ forloop.index0 }}" aria-label="Slide {{ forloop.index }}"></button>
        {%- endfor -%}
      </div>
      <button class="hero__control hero__control--next" data-hero-next aria-label="{{ 'accessibility.next_slide' | t }}">
        {%- render 'icon', icon: 'chevron-right' -%}
      </button>
    </div>
  {%- endif -%}
</div>

{% javascript %}
(function() {
  var hero = document.querySelector('[data-hero]');
  if (!hero) return;

  var slides = hero.querySelectorAll('[data-hero-slide]');
  if (slides.length <= 1) return;

  var prevBtn = hero.querySelector('[data-hero-prev]');
  var nextBtn = hero.querySelector('[data-hero-next]');
  var dots = hero.querySelectorAll('[data-hero-dot]');
  var currentIndex = 0;
  var autoplayInterval = null;
  var speed = parseInt(hero.getAttribute('data-autoplay-speed') || '5', 10) * 1000;

  function goToSlide(index) {
    if (index < 0) {
      index = slides.length - 1;
    } else if (index >= slides.length) {
      index = 0;
    }

    for (var i = 0; i < slides.length; i++) {
      slides[i].classList.remove('hero__slide--active');
    }
    slides[index].classList.add('hero__slide--active');

    for (var j = 0; j < dots.length; j++) {
      dots[j].classList.remove('hero__dot--active');
    }
    dots[index].classList.add('hero__dot--active');

    currentIndex = index;
  }

  function nextSlide() {
    goToSlide(currentIndex + 1);
  }

  function prevSlide() {
    goToSlide(currentIndex - 1);
  }

  function startAutoplay() {
    stopAutoplay();
    autoplayInterval = setInterval(nextSlide, speed);
  }

  function stopAutoplay() {
    if (autoplayInterval) {
      clearInterval(autoplayInterval);
      autoplayInterval = null;
    }
  }

  if (prevBtn) {
    prevBtn.addEventListener('click', function() {
      prevSlide();
      startAutoplay();
    });
  }

  if (nextBtn) {
    nextBtn.addEventListener('click', function() {
      nextSlide();
      startAutoplay();
    });
  }

  for (var d = 0; d < dots.length; d++) {
    (function(dotIndex) {
      dots[dotIndex].addEventListener('click', function() {
        goToSlide(dotIndex);
        startAutoplay();
      });
    })(d);
  }

  hero.addEventListener('mouseenter', function() {
    stopAutoplay();
  });

  hero.addEventListener('mouseleave', function() {
    startAutoplay();
  });

  startAutoplay();
})();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.hero_banner.name",
  "class": "section-hero-banner",
  "settings": [
    {
      "type": "select",
      "id": "height",
      "default": "medium",
      "label": "t:sections.hero_banner.settings.height.label",
      "options": [
        {
          "value": "small",
          "label": "t:sections.hero_banner.settings.height.options.small"
        },
        {
          "value": "medium",
          "label": "t:sections.hero_banner.settings.height.options.medium"
        },
        {
          "value": "large",
          "label": "t:sections.hero_banner.settings.height.options.large"
        },
        {
          "value": "full",
          "label": "t:sections.hero_banner.settings.height.options.full"
        }
      ]
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 5,
      "unit": "s",
      "label": "t:sections.hero_banner.settings.autoplay_speed.label"
    },
    {
      "type": "range",
      "id": "padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px",
      "label": "t:sections.hero_banner.settings.padding.label"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "t:sections.hero_banner.blocks.slide.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.hero_banner.blocks.slide.settings.image.label"
        },
        {
          "type": "richtext",
          "id": "heading",
          "default": "<p>Everyday Wear, <strong>Elevated.<\/strong></p>",
          "label": "t:sections.hero_banner.blocks.slide.settings.heading.label"
        },
        {
          "type": "textarea",
          "id": "subheading",
          "label": "t:sections.hero_banner.blocks.slide.settings.subheading.label"
        },
        {
          "type": "text",
          "id": "button_label",
          "default": "New In",
          "label": "t:sections.hero_banner.blocks.slide.settings.button_label.label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "t:sections.hero_banner.blocks.slide.settings.button_link.label"
        },
        {
          "type": "select",
          "id": "text_alignment",
          "default": "left",
          "label": "t:sections.hero_banner.blocks.slide.settings.text_alignment.label",
          "options": [
            {
              "value": "left",
              "label": "t:sections.hero_banner.blocks.slide.settings.text_alignment.options.left"
            },
            {
              "value": "center",
              "label": "t:sections.hero_banner.blocks.slide.settings.text_alignment.options.center"
            },
            {
              "value": "right",
              "label": "t:sections.hero_banner.blocks.slide.settings.text_alignment.options.right"
            }
          ]
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "min": 0,
          "max": 100,
          "step": 5,
          "default": 10,
          "label": "t:sections.hero_banner.blocks.slide.settings.overlay_opacity.label"
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "t:sections.hero_banner.presets.hero_banner.name",
      "blocks": [
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
