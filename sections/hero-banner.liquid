{%- liquid
  assign heading = section.settings.heading
  assign content = section.settings.content
  assign btn_label = section.settings.button_label
  assign btn_link = section.settings.button_link
  assign btn_style = section.settings.button_style
  assign image_mobile = section.settings.image_mobile
  assign image_tablet = section.settings.image_tablet
  assign image_desktop = section.settings.image_desktop
  assign heading_size = section.settings.heading_size
  assign font_color = section.settings.font_color
  assign overlay_opacity = section.settings.overlay_opacity
  assign content_gap = section.settings.content_gap
  assign mobile_align = section.settings.mobile_alignment
  assign desktop_align = section.settings.desktop_alignment
  assign mobile_position = section.settings.mobile_position
  assign desktop_position = section.settings.desktop_position
  assign min_height_mobile = section.settings.min_height_mobile
  assign min_height_desktop = section.settings.min_height_desktop
-%}

<section
  class="hero-banner"
  style="
    --hero-content-gap: {{ content_gap }}px;
    --hero-min-height-mobile: {{ min_height_mobile }}px;
    --hero-min-height-desktop: {{ min_height_desktop }}px;
  "
>
  <div class="hero-banner__media">
    {%- if image_mobile -%}
      <img
        class="hero-banner__image hero-banner__image--mobile"
        src="{{ image_mobile | image_url: width: 800 }}"
        srcset="
          {{ image_mobile | image_url: width: 400 }} 400w,
          {{ image_mobile | image_url: width: 600 }} 600w,
          {{ image_mobile | image_url: width: 800 }} 800w
        "
        sizes="100vw"
        alt="{{ image_mobile.alt | escape }}"
        loading="eager"
        width="{{ image_mobile.width }}"
        height="{{ image_mobile.height }}"
      >
    {%- else -%}
      <img
        class="hero-banner__image hero-banner__image--mobile"
        src="{{ 'hero-mobile.png' | asset_url }}"
        alt="Hero banner"
        loading="eager"
      >
    {%- endif -%}

    {%- if image_tablet -%}
      <img
        class="hero-banner__image hero-banner__image--tablet"
        src="{{ image_tablet | image_url: width: 1200 }}"
        srcset="
          {{ image_tablet | image_url: width: 768 }} 768w,
          {{ image_tablet | image_url: width: 1000 }} 1000w,
          {{ image_tablet | image_url: width: 1200 }} 1200w
        "
        sizes="100vw"
        alt="{{ image_tablet.alt | escape }}"
        loading="eager"
        width="{{ image_tablet.width }}"
        height="{{ image_tablet.height }}"
      >
    {%- endif -%}

    {%- if image_desktop -%}
      <img
        class="hero-banner__image hero-banner__image--desktop"
        src="{{ image_desktop | image_url: width: 1920 }}"
        srcset="
          {{ image_desktop | image_url: width: 1200 }} 1200w,
          {{ image_desktop | image_url: width: 1600 }} 1600w,
          {{ image_desktop | image_url: width: 1920 }} 1920w
        "
        sizes="100vw"
        alt="{{ image_desktop.alt | escape }}"
        loading="eager"
        width="{{ image_desktop.width }}"
        height="{{ image_desktop.height }}"
      >
    {%- else -%}
      <img
        class="hero-banner__image hero-banner__image--desktop"
        src="{{ 'hero-desktop.jpeg' | asset_url }}"
        alt="Hero banner"
        loading="eager"
      >
    {%- endif -%}
  </div>


  <div class="hero-banner__container">
    <div
      class="hero-banner__inner hero-banner__inner--mobile-{{ mobile_position }} hero-banner__inner--desktop-{{ desktop_position }}"
      style="min-height: var(--hero-min-height-mobile);"
    >
      <div
        class="hero-banner__content hero-banner__content--mobile-{{ mobile_align }} hero-banner__content--desktop-{{ desktop_align }}"
        style="color: {{ font_color }};"
      >
        {%- if heading != blank -%}
          <h1 class="hero-banner__heading hero-banner__heading--{{ heading_size }}">
            {{ heading }}
          </h1>
        {%- endif -%}

        {%- if content != blank -%}
          <p class="hero-banner__text">{{ content }}</p>
        {%- endif -%}

        {%- if btn_label != blank -%}
          <div class="hero-banner__btn">
            <a
              href="{{ btn_link }}"
              class="hero-banner__btn-link"
            >
              {{ btn_label }}
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  @media screen and (min-width: 990px) {
    .hero-banner__inner {
      min-height: var(--hero-min-height-desktop) !important;
    }
  }
</style>

{% schema %}
{
  "name": "Hero banner",
  "class": "section-hero-banner",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image"
    },
    {
      "type": "image_picker",
      "id": "image_tablet",
      "label": "Tablet image"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 0,
      "unit": "%",
      "label": "Overlay opacity"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New Collection"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "lg",
      "options": [
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" }
      ]
    },
    {
      "type": "textarea",
      "id": "content",
      "label": "Content text"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "default": "primary",
      "options": [
        { "value": "primary", "label": "Filled" },
        { "value": "outline", "label": "Outline" }
      ]
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "color",
      "id": "font_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "content_gap",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 16,
      "unit": "px",
      "label": "Space between content"
    },
    {
      "type": "header",
      "content": "Layout — Mobile"
    },
    {
      "type": "select",
      "id": "mobile_alignment",
      "label": "Mobile text alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "mobile_position",
      "label": "Mobile vertical position",
      "default": "center",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ]
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "min": 300,
      "max": 800,
      "step": 50,
      "default": 500,
      "unit": "px",
      "label": "Mobile minimum height"
    },
    {
      "type": "header",
      "content": "Layout — Desktop"
    },
    {
      "type": "select",
      "id": "desktop_alignment",
      "label": "Desktop text alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "desktop_position",
      "label": "Desktop vertical position",
      "default": "center",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ]
    },
    {
      "type": "range",
      "id": "min_height_desktop",
      "min": 400,
      "max": 900,
      "step": 50,
      "default": 600,
      "unit": "px",
      "label": "Desktop minimum height"
    }
  ],
  "presets": [
    {
      "name": "Hero banner"
    }
  ]
}
{% endschema %}
