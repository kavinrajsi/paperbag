{%- liquid
  assign title = section.settings.title
  assign show_title = section.settings.show_title
  assign container_type = section.settings.container_type
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign bg_color = section.settings.bg_color
  assign text_color = section.settings.text_color
-%}

{%- if section.blocks.size > 0 -%}
  <section
    class="masonry-grid"
    style="
      --mg-padding-top: {{ padding_top }}px;
      --mg-padding-bottom: {{ padding_bottom }}px;
      --mg-bg-color: {{ bg_color }};
      --mg-text-color: #313d65;
    "
  >
    <div class="masonry-grid__wrapper masonry-grid__wrapper--{{ container_type }}">

      {%- if show_title and title != blank -%}
        <div class="section-title__heading">
          <h2 class="section-title">{{ title }}</h2>
        </div>
      {%- endif -%}

      <div class="masonry-grid__items">
        {%- for block in section.blocks -%}
          {%- assign image = block.settings.image -%}
          {%- assign label = block.settings.label -%}
          {%- assign link = block.settings.link -%}
          {%- assign content_text = block.settings.content -%}
          {%- assign item_bg = block.settings.item_bg_color -%}

          <div class="masonry-grid__item" {{ block.shopify_attributes }}>
            {%- if link != blank -%}
              <a href="{{ link }}" class="masonry-grid__link">
            {%- endif -%}

              <div
                class="masonry-grid__card{% unless image %} masonry-grid__card--color{% endunless %}"
                {% unless image %}style="background-color: {{ item_bg }};"{% endunless %}
              >
                {%- if image -%}
                  <img
                    class="masonry-grid__image"
                    src="{{ image | image_url: width: 1200 }}"
                    srcset="
                      {{ image | image_url: width: 400 }} 400w,
                      {{ image | image_url: width: 600 }} 600w,
                      {{ image | image_url: width: 900 }} 900w,
                      {{ image | image_url: width: 1200 }} 1200w
                    "
                    sizes="(min-width: 990px) 45vw, 50vw"
                    alt="{{ image.alt | default: label | escape }}"
                    loading="lazy"
                    width="{{ image.width }}"
                    height="{{ image.height }}"
                  >
                {%- endif -%}

                {%- if content_text != blank -%}
                  <p class="masonry-grid__content">{{ content_text }}</p>
                {%- endif -%}

                {%- if label != blank -%}
                  <span class="masonry-grid__label">{{ label }}</span>
                {%- endif -%}
              </div>

            {%- if link != blank -%}
              </a>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Masonry grid",
  "class": "section-masonry-grid",
  "settings": [
    {
      "type": "header",
      "content": "Section title"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show title",
      "default": true
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Shop Our Collections"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_type",
      "label": "Container type",
      "default": "container",
      "options": [
        { "value": "container", "label": "Container" },
        { "value": "container-fluid", "label": "Container fluid" }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 64,
      "unit": "px",
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 64,
      "unit": "px",
      "label": "Padding bottom"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#313d65"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Grid item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Collection"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "textarea",
          "id": "content",
          "label": "Content text (shown when no image)"
        },
        {
          "type": "color",
          "id": "item_bg_color",
          "label": "Background color (when no image)",
          "default": "#8fa1b7"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Masonry grid",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "label": "Summer Collection"
          }
        },
        {
          "type": "item",
          "settings": {
            "label": "Office Collection"
          }
        },
        {
          "type": "item",
          "settings": {
            "label": "Fall Collection"
          }
        },
        {
          "type": "item",
          "settings": {
            "label": "Shop Collection",
            "content": "Wardrobe essentials, redefined."
          }
        }
      ]
    }
  ]
}
{% endschema %}
