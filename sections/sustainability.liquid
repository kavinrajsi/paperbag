{%- liquid
  assign image_mobile = section.settings.image_mobile
  assign image_desktop = section.settings.image_desktop
  assign text = section.settings.text
  assign button_label = section.settings.button_label
  assign button_link = section.settings.button_link
-%}

<section class="sustainability" data-section-id="{{ section.id }}">
  <div class="sustainability__media">
    {%- if image_mobile != blank -%}
      <img
        class="sustainability__image sustainability__image--mobile"
        src="{{ image_mobile | image_url: width: 800 }}"
        srcset="
          {{ image_mobile | image_url: width: 400 }} 400w,
          {{ image_mobile | image_url: width: 600 }} 600w,
          {{ image_mobile | image_url: width: 800 }} 800w
        "
        sizes="100vw"
        alt="{{ image_mobile.alt | escape }}"
        loading="lazy"
        width="{{ image_mobile.width }}"
        height="{{ image_mobile.height }}"
      >
    {%- else -%}
      <img
        class="sustainability__image sustainability__image--mobile"
        src="{{ 'sustainability-mobile.png' | asset_url }}"
        alt="Sustainability"
        loading="lazy"
      >
    {%- endif -%}

    {%- if image_desktop != blank -%}
      <img
        class="sustainability__image sustainability__image--desktop"
        src="{{ image_desktop | image_url: width: 1920 }}"
        srcset="
          {{ image_desktop | image_url: width: 1200 }} 1200w,
          {{ image_desktop | image_url: width: 1600 }} 1600w,
          {{ image_desktop | image_url: width: 1920 }} 1920w
        "
        sizes="100vw"
        alt="{{ image_desktop.alt | escape }}"
        loading="lazy"
        width="{{ image_desktop.width }}"
        height="{{ image_desktop.height }}"
      >
    {%- else -%}
      <img
        class="sustainability__image sustainability__image--desktop"
        src="{{ 'sustainability-desktop.png' | asset_url }}"
        alt="Sustainability"
        loading="lazy"
      >
    {%- endif -%}
  </div>

  <div class="sustainability__content">
    {%- if text != blank -%}
      <p class="sustainability__text">{{ text }}</p>
    {%- endif -%}

    {%- if button_label != blank -%}
      <a href="{{ button_link | default: '#' }}" class="sustainability__btn">
        {{ button_label }}
      </a>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .sustainability {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .sustainability__media {
    width: 100%;
  }

  .sustainability__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sustainability__image--mobile {
    display: block;
  }

  .sustainability__image--desktop {
    display: none;
  }

  @media screen and (min-width: 990px) {
    .sustainability__image--mobile {
      display: none;
    }

    .sustainability__image--desktop {
      display: block;
    }
  }

  .sustainability__placeholder {
    width: 100%;
    aspect-ratio: 1440 / 440;
    background-color: #d5cfc5;
  }

  /* ── Overlaid content ── */
  .sustainability__content {
    position: absolute;
    right: 0;
    bottom: 0;
    width: 50%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-end;
    text-align: right;
    padding: 48px max(32px, calc((100vw - 1200px) / 2 + 32px)) 48px 0;
  }

  .sustainability__text {
    font-family: 'Outfit', sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 18px;
    color: #272F25;
    text-transform: capitalize;
    margin: 0 0 24px;
    max-width: 618px;
  }

  .sustainability__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 40px;
    background-color: var(--color-brand);
    color: #FAF8F3;
    font-family: 'Outfit', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 20px;
    text-decoration: none;
    border-radius: 6px;
    transition: opacity 0.2s ease;
    white-space: nowrap;
  }

  .sustainability__btn:hover {
    opacity: 0.9;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 989px) {
    .sustainability__content {
      width: 100%;
      justify-content: flex-end;
      align-items: flex-end;
      text-align: right;
      padding: 24px 20px;
    }

    .sustainability__text {
      max-width: 225px;
      margin-bottom: 12px;
    }

    .sustainability__btn {
      padding: 10px 24px;
      font-size: 14px;
      align-self: flex-end;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.sustainability.name",
  "class": "section-sustainability",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop image"
    },
    {
      "type": "text",
      "id": "text",
      "default": "Where comfort meets conscience. Our fabrics are soft on you and gentle on the planet.",
      "label": "t:sections.sustainability.settings.text.label"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "About Us",
      "label": "t:sections.sustainability.settings.button_label.label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.sustainability.settings.button_link.label"
    }
  ],
  "presets": [
    {
      "name": "Sustainability"
    }
  ]
}
{% endschema %}
