{%- paginate collection.products by section.settings.products_per_page -%}
<div class="collection-page" data-section-id="{{ section.id }}">

  {%- if collection.image != blank -%}
    <div class="collection-page__banner">
      {%- render 'image', image: collection.image, widths: '750,1000,1440,1920', sizes: '100vw', lazy: false -%}
    </div>
  {%- endif -%}

  <div class="container">
    <div class="collection-page__layout">
      {%- comment -%} Sidebar filters {%- endcomment -%}
      {%- if section.settings.enable_filtering -%}
        <aside class="collection-page__sidebar" data-collection-sidebar>
          <div class="collection-page__sidebar-header">
            <h2 class="collection-page__sidebar-heading">Filter</h2>
            <button type="button" class="collection-page__sidebar-close" data-mobile-filter-close aria-label="Close filters">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          </div>

          {%- for filter in collection.filters -%}
            <div class="collection-page__filter-bar" data-filter-accordion>
              <button type="button" class="collection-page__filter-btn" data-filter-accordion-toggle aria-expanded="false">
                <span>{{ filter.label }}</span>
                <svg class="collection-page__filter-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="collection-page__filter-panel" data-filter-accordion-panel hidden>
                {%- if filter.type == 'list' -%}
                  {%- for value in filter.values -%}
                    <label class="collection-page__filter-option">
                      <input
                        type="checkbox"
                        name="{{ value.param_name }}"
                        value="{{ value.value }}"
                        {% if value.active %}checked{% endif %}
                        {% if value.count == 0 and value.active == false %}disabled{% endif %}
                        data-filter-checkbox
                      >
                      {{ value.label }} ({{ value.count }})
                    </label>
                  {%- endfor -%}
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}

          <div class="collection-page__sidebar-actions">
            <button type="button" class="collection-page__sidebar-apply" data-mobile-filter-apply>View Items</button>
          </div>
        </aside>

        {%- comment -%} Mobile filter + sort bar {%- endcomment -%}
        <div class="collection-page__mobile-bar">
          <button type="button" class="collection-page__mobile-filter-btn" data-mobile-filter-toggle>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="10" y1="18" x2="14" y2="18"/></svg>
            Filter
          </button>
          <button type="button" class="collection-page__mobile-sort-btn" data-mobile-sort-toggle>
            Sort By
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
        </div>

        {%- comment -%} Sort bottom sheet {%- endcomment -%}
        <div class="collection-page__sort-drawer" data-sort-drawer>
          <div class="collection-page__sort-backdrop" data-sort-backdrop></div>
          <div class="collection-page__sort-panel">
            <div class="collection-page__sort-header">
              <button type="button" class="collection-page__sort-close" data-sort-close aria-label="Close sort">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </button>
              <span class="collection-page__sort-title">Sort</span>
              <span></span>
            </div>
            <div class="collection-page__sort-divider"></div>
            <ul class="collection-page__sort-options">
              {%- for option in collection.sort_options -%}
                <li>
                  <button type="button" class="collection-page__sort-option{% if collection.sort_by == option.value %} collection-page__sort-option--active{% endif %}" data-sort-value="{{ option.value }}">
                    {{ option.name }}
                  </button>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} Product grid {%- endcomment -%}
      <div class="collection-page__products">
        {%- assign has_active = false -%}
        {%- for filter in collection.filters -%}
          {%- if filter.active_values.size > 0 -%}
            {%- assign has_active = true -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if has_active -%}
          <div class="collection-page__active-filters">
            {%- for filter in collection.filters -%}
              {%- for value in filter.active_values -%}
                <a href="{{ value.url_to_remove }}" class="collection-page__chip">
                  {{ value.label }}
                  <svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 1L9 9M9 1L1 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </a>
              {%- endfor -%}
            {%- endfor -%}

            <a href="{{ collection.url }}" class="collection-page__clear-filters">
              Clear All
            </a>
          </div>
        {%- endif -%}

        {%- if collection.products.size > 0 -%}
          <div class="collection-page__grid">
            {%- for product in collection.products -%}
              {%- assign current_variant = product.selected_or_first_available_variant -%}
              <div class="collection-page__item">
                <div class="scroll-collection__card">
                  <a href="{{ product.url }}" class="scroll-collection__media">
                    {%- if product.featured_image -%}
                      <img
                        class="scroll-collection__image"
                        src="{{ product.featured_image | image_url }}"
                        alt="{{ product.title | escape }}"
                        loading="lazy"
                      >
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'scroll-collection__placeholder' }}
                    {%- endif -%}
                  </a>
                  <div class="scroll-collection__body">
                    <div class="scroll-collection__info">
                      <p class="scroll-collection__name">
                        <a href="{{ product.url }}">{{ product.title }}</a>
                      </p>
                      <p class="scroll-collection__price">
                        {{ current_variant.price | money }}
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          </div>

          {%- if paginate.pages > 1 -%}
            <nav class="collection-page__pagination" aria-label="Pagination">
              {%- if paginate.previous -%}
                <a href="{{ paginate.previous.url }}" class="pagination__btn pagination__btn--prev" aria-label="Previous page">
                  &larr;
                </a>
              {%- endif -%}

              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a href="{{ part.url }}" class="pagination__page">{{ part.title }}</a>
                {%- elsif part.title == paginate.current_page -%}
                  <span class="pagination__page pagination__page--current" aria-current="page">{{ part.title }}</span>
                {%- else -%}
                  <span class="pagination__page pagination__page--gap">{{ part.title }}</span>
                {%- endif -%}
              {%- endfor -%}

              {%- if paginate.next -%}
                <a href="{{ paginate.next.url }}" class="pagination__btn pagination__btn--next" aria-label="Next page">
                  &rarr;
                </a>
              {%- endif -%}
            </nav>
          {%- endif -%}
        {%- else -%}
          <p class="collection-page__empty">{{ 'collections.empty' | t | default: 'No products found' }}</p>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>
{%- endpaginate -%}

{% stylesheet %}
  .collection-page {
    padding-bottom: 64px;
  }


  /* ── Banner ── */
  .collection-page__banner {
    width: 100%;
    max-height: 655px;
    overflow: hidden;
    margin-bottom: 40px;
  }

  .collection-page__banner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Layout: sidebar + products ── */
  .collection-page__layout {
    display: grid;
    grid-template-columns: 30% 1fr;
    gap: 24px;
    align-items: start;
  }

  /* ── Sidebar ── */
  .collection-page__sidebar {
    position: sticky;
    top: 10px;
  }

  .collection-page__sidebar-heading {
    font-family: 'Outfit', sans-serif;
    font-size: 32px;
    line-height: 1.2;
    color: #313D65;
    font-weight: normal;
    font-style: normal;
    margin: 0 0 16px;
  }

  .collection-page__sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--color-muted);
    margin-bottom: 8px;
  }

  .collection-page__sidebar-close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: var(--color-text);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .collection-page__filter-bar {
    border-bottom: 1px solid var(--color-muted);
  }

  .collection-page__filter-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 16px 0;
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .collection-page__filter-chevron {
    flex-shrink: 0;
    transition: transform 0.2s ease;
    color: var(--color-text);
  }

  .collection-page__filter-btn[aria-expanded="true"] .collection-page__filter-chevron {
    transform: rotate(180deg);
  }

  .collection-page__filter-panel {
    padding: 4px 0 16px;
    background: none;
  }

  .collection-page__filter-option {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 0;
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    color: var(--color-black);
    cursor: pointer;
  }

  /* ── Custom checkbox ── */
  .collection-page__filter-option input[type="checkbox"] {
    -webkit-appearance: none;
    appearance: none;
    width: 18px;
    height: 18px;
    border: 1.5px solid var(--color-brand);
    border-radius: 4px;
    background: #fff;
    cursor: pointer;
    flex-shrink: 0;
    position: relative;
    transition: all 0.15s ease;
  }

  .collection-page__filter-option input[type="checkbox"]:checked {
    background: var(--color-brand);
    border-color: var(--color-brand);
  }

  .collection-page__filter-option input[type="checkbox"]:checked::after {
    content: '';
    position: absolute;
    left: 5px;
    top: 2px;
    width: 5px;
    height: 9px;
    border: solid #fff;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }

  .collection-page__filter-option input[type="checkbox"]:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  /* ── Custom radio ── */
  .collection-page__filter-option input[type="radio"] {
    -webkit-appearance: none;
    appearance: none;
    width: 18px;
    height: 18px;
    border: 1.5px solid var(--color-brand);
    border-radius: 50%;
    background: #fff;
    cursor: pointer;
    flex-shrink: 0;
    position: relative;
    transition: all 0.15s ease;
  }

  .collection-page__filter-option input[type="radio"]:checked {
    border-color: var(--color-brand);
  }

  .collection-page__filter-option input[type="radio"]:checked::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-brand);
  }

  /* ── Active filter chips ── */
  .collection-page__active-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
    align-items: center;
  }

  .collection-page__chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    height: 34px;
    padding: 0 12px;
    background: var(--color-brand);
    border: 1px solid var(--color-brand);
    color: #faf8f3;
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    font-weight: 400;
    border-radius: 6px;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .collection-page__chip:hover {
    opacity: 0.85;
  }

  .collection-page__chip svg {
    flex-shrink: 0;
  }

  .collection-page__clear-filters {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 34px;
    padding: 0 12px;
    background: transparent;
    color: var(--color-brand);
    border: 1px solid var(--color-brand);
    border-radius: 6px;
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    font-weight: 400;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .collection-page__clear-filters:hover {
    background: var(--color-brand);
    color: #faf8f3;
  }

  /* ── Mobile bar (hidden on desktop) ── */
  .collection-page__mobile-bar {
    display: none;
  }

  /* ── Sort drawer (hidden by default) ── */
  .collection-page__sort-drawer {
    display: none;
  }

  .collection-page__sort-drawer--open {
    display: block;
  }

  .collection-page__sort-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    z-index: 148;
  }

  .collection-page__sort-panel {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: #fff;
    z-index: 149;
    border-radius: 16px 16px 0 0;
    padding: 24px 20px 40px;
    transform: translateY(100%);
    transition: transform 0.3s ease;
  }

  .collection-page__sort-drawer--open .collection-page__sort-panel {
    transform: translateY(0);
  }

  .collection-page__sort-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .collection-page__sort-title {
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text);
  }

  .collection-page__sort-close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: var(--color-text);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .collection-page__sort-divider {
    height: 1px;
    background: var(--color-muted);
    margin-bottom: 8px;
  }

  .collection-page__sort-options {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .collection-page__sort-option {
    display: block;
    width: 100%;
    padding: 14px 0;
    background: none;
    border: none;
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: var(--color-text-secondary);
    text-align: center;
    cursor: pointer;
    transition: color 0.15s ease;
  }

  .collection-page__sort-option--active {
    font-weight: 700;
    color: var(--color-text);
  }

  .collection-page__sort-option:hover {
    color: var(--color-text);
  }

  .collection-page__sidebar-actions {
    display: none;
  }

  /* ── Product grid: 2 columns ── */
  .collection-page__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  @media (min-width: 768px) {
    .collection-page__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }

  /* ── Empty state ── */
  .collection-page__empty {
    font-family: 'Outfit', sans-serif;
    font-size: 18px;
    color: #ADADAD;
    text-align: center;
    padding: 48px 0;
  }

  /* ── Pagination ── */
  .collection-page__pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 40px;
  }

  .pagination__page,
  .pagination__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 40px;
    padding: 0 8px;
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #313D65;
    text-decoration: none;
    border: 1px solid transparent;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .pagination__page:hover,
  .pagination__btn:hover {
    border-color: #313D65;
  }

  .pagination__page--current {
    background-color: #313D65;
    color: #fff;
    border-color: #313D65;
  }

  .pagination__page--gap {
    border: none;
    cursor: default;
  }

  .pagination__page--gap:hover {
    border-color: transparent;
  }

  /* ── Tablet (750–989px) ── */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .collection-page__layout {
      grid-template-columns: 30% 1fr;
      gap: 20px;
    }

    .collection-page__sidebar-heading {
      font-size: 24px;
    }

    .collection-page__filter-btn {
      font-size: 16px;
      height: 42px;
    }
  }

  /* ── Mobile (< 750px) ── */
  @media screen and (max-width: 749px) {
    .collection-page {
      padding-bottom: 40px;
    }

    .collection-page__banner {
      max-height: 300px;
      margin-bottom: 24px;
    }

    .collection-page__layout {
      grid-template-columns: 1fr;
      gap: 0;
    }

    /* Hide sidebar on mobile by default */
    .collection-page__sidebar {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      max-width: 100%;
      height: 100%;
      background: #fff;
      z-index: 150;
      padding: 24px 20px 72px;
      overflow-y: auto;
      transform: translateX(-100%);
      transition: transform 0.3s ease;
      box-shadow: 2px 0 12px rgba(0, 0, 0, 0.1);
    }

    .collection-page__sidebar--open {
      transform: translateX(0);
    }

    .collection-page__mobile-bar {
      display: flex;
      gap: 12px;
      margin-bottom: 20px;
    }

    .collection-page__mobile-filter-btn,
    .collection-page__mobile-sort-btn {
      flex: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      height: 44px;
      background: none;
      border: 1px solid var(--color-text);
      font-family: 'Outfit', sans-serif;
      font-size: 14px;
      font-weight: 400;
      color: var(--color-text);
      cursor: pointer;
    }

    .collection-page__sidebar-heading {
      font-size: 24px;
      margin-bottom: 0;
    }

    .collection-page__sidebar-actions {
      display: flex;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 151;
    }

    .collection-page__sidebar-apply {
      flex: 1;
      height: 56px;
      border: none;
      background: var(--color-brand);
      color: #fff;
      font-family: 'Outfit', sans-serif;
      font-size: 14px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      cursor: pointer;
    }

    .collection-page__grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
{% endstylesheet %}

{% javascript %}
(function() {
  'use strict';

  // Accordion toggles
  var accordions = document.querySelectorAll('[data-filter-accordion-toggle]');
  for (var i = 0; i < accordions.length; i++) {
    accordions[i].addEventListener('click', function() {
      var panel = this.parentElement.querySelector('[data-filter-accordion-panel]');
      if (!panel) return;
      var isOpen = !panel.hidden;
      panel.hidden = isOpen;
      this.setAttribute('aria-expanded', String(!isOpen));
    });
  }

  // Filter checkboxes auto-submit (desktop only, skip when mobile drawer is open)
  var checkboxes = document.querySelectorAll('[data-filter-checkbox]');
  var sidebarEl = document.querySelector('[data-collection-sidebar]');
  for (var k = 0; k < checkboxes.length; k++) {
    checkboxes[k].addEventListener('change', function() {
      if (sidebarEl && sidebarEl.classList.contains('collection-page__sidebar--open')) return;
      var url = new URL(window.location.href);
      var checked = document.querySelectorAll('[data-filter-checkbox]:checked');
      var params = new URLSearchParams();
      if (url.searchParams.get('sort_by')) {
        params.set('sort_by', url.searchParams.get('sort_by'));
      }
      for (var l = 0; l < checked.length; l++) {
        params.append(checked[l].name, checked[l].value);
      }
      window.location.href = url.pathname + '?' + params.toString();
    });
  }

  // Sort drawer
  var sortDrawer = document.querySelector('[data-sort-drawer]');
  var sortToggle = document.querySelector('[data-mobile-sort-toggle]');
  var sortClose = document.querySelector('[data-sort-close]');
  var sortBackdrop = document.querySelector('[data-sort-backdrop]');
  if (sortDrawer && sortToggle) {
    sortToggle.addEventListener('click', function() {
      sortDrawer.classList.add('collection-page__sort-drawer--open');
      document.body.style.overflow = 'hidden';
    });
    function closeSortDrawer() {
      sortDrawer.classList.remove('collection-page__sort-drawer--open');
      document.body.style.overflow = '';
    }
    if (sortClose) sortClose.addEventListener('click', closeSortDrawer);
    if (sortBackdrop) sortBackdrop.addEventListener('click', closeSortDrawer);
    var sortOptions = document.querySelectorAll('[data-sort-value]');
    for (var s = 0; s < sortOptions.length; s++) {
      sortOptions[s].addEventListener('click', function() {
        var url = new URL(window.location.href);
        url.searchParams.set('sort_by', this.getAttribute('data-sort-value'));
        window.location.href = url.toString();
      });
    }
  }

  // Mobile filter drawer
  var sidebar = document.querySelector('[data-collection-sidebar]');
  var mobileToggle = document.querySelector('[data-mobile-filter-toggle]');
  if (sidebar && mobileToggle) {
    var backdrop = document.createElement('div');
    backdrop.className = 'collection-page__sidebar-backdrop';
    backdrop.style.cssText = 'display:none;position:fixed;inset:0;background:rgba(0,0,0,0.3);z-index:149;';
    sidebar.parentElement.appendChild(backdrop);

    mobileToggle.addEventListener('click', function() {
      sidebar.classList.add('collection-page__sidebar--open');
      backdrop.style.display = 'block';
      document.body.style.overflow = 'hidden';
    });

    function closeSidebar() {
      sidebar.classList.remove('collection-page__sidebar--open');
      backdrop.style.display = 'none';
      document.body.style.overflow = '';
    }

    backdrop.addEventListener('click', closeSidebar);

    var closeBtn = document.querySelector('[data-mobile-filter-close]');
    if (closeBtn) closeBtn.addEventListener('click', closeSidebar);

    var applyBtn = document.querySelector('[data-mobile-filter-apply]');
    if (applyBtn) {
      applyBtn.addEventListener('click', function() {
        var url = new URL(window.location.href);
        var checked = sidebar.querySelectorAll('[data-filter-checkbox]:checked');
        var params = new URLSearchParams();
        if (url.searchParams.get('sort_by')) {
          params.set('sort_by', url.searchParams.get('sort_by'));
        }
        for (var i = 0; i < checked.length; i++) {
          params.append(checked[i].name, checked[i].value);
        }
        window.location.href = url.pathname + '?' + params.toString();
      });
    }
  }
})();
{% endjavascript %}

