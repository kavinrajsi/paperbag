{%- liquid
  assign heading = section.settings.heading
  assign subtext = section.settings.subtext
  assign color_scheme = section.settings.color_scheme
-%}

<section class="newsletter newsletter--{{ color_scheme }}" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="newsletter__inner">
      {%- if heading != blank -%}
        <h2 class="newsletter__heading">{{ heading }}</h2>
      {%- endif -%}

      {%- if subtext != blank -%}
        <div class="newsletter__subtext rte">{{ subtext }}</div>
      {%- endif -%}

      {% form 'customer', class: 'newsletter__form' %}
        {%- if form.posted_successfully? -%}
          <p class="newsletter__success">{{ 'sections.newsletter.success' | t }}</p>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="newsletter__errors">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="newsletter__input-group">
          <input type="email" name="contact[email]" placeholder="{{ 'sections.newsletter.email_placeholder' | t }}" required class="form__input">
          <button type="submit" class="btn btn--primary">{{ 'sections.newsletter.submit' | t }}</button>
        </div>
      {% endform %}
    </div>
  </div>
</section>

{% stylesheet %}
  .newsletter {
    padding: 48px 0;
  }

  .newsletter--dark {
    background-color: var(--color-primary);
    color: #fff;
  }

  .newsletter__inner {
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }

  .newsletter__heading {
    font-size: 2rem;
    margin-bottom: 12px;
  }

  .newsletter__subtext {
    margin-bottom: 24px;
    line-height: 1.6;
  }

  .newsletter__form {
    width: 100%;
  }

  .newsletter__input-group {
    display: flex;
    gap: 8px;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  .newsletter__input-group .form__input {
    flex: 1;
  }

  .newsletter__success {
    margin-bottom: 16px;
    color: #16a34a;
  }

  .newsletter--dark .newsletter__success {
    color: #4ade80;
  }

  .newsletter__errors {
    margin-bottom: 16px;
    color: #dc2626;
  }

  @media screen and (max-width: 749px) {
    .newsletter__input-group {
      flex-direction: column;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.newsletter.name",
  "class": "section-newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Subscribe to our newsletter",
      "label": "t:sections.newsletter.settings.heading.label"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "default": "<p>Be the first to know about new collections and exclusive offers.</p>",
      "label": "t:sections.newsletter.settings.subtext.label"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "default": "light",
      "label": "t:sections.newsletter.settings.color_scheme.label",
      "options": [
        {
          "value": "light",
          "label": "t:sections.newsletter.settings.color_scheme.options.light"
        },
        {
          "value": "dark",
          "label": "t:sections.newsletter.settings.color_scheme.options.dark"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
