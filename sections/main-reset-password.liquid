{%- liquid
  assign image_mobile = section.settings.image_mobile
  assign image_desktop = section.settings.image_desktop
-%}

<div class="reset-page">
  <div class="reset-page__container">
    <div class="reset-page__layout">

      {%- comment -%} Image column {%- endcomment -%}
      <div class="reset-page__image-col">
        {%- if image_mobile != blank -%}
          <img
            class="reset-page__image reset-page__image--mobile"
            src="{{ image_mobile | image_url: width: 800 }}"
            alt="{{ image_mobile.alt | escape }}"
            loading="lazy"
          >
        {%- endif -%}
        {%- if image_desktop != blank -%}
          <img
            class="reset-page__image reset-page__image--desktop"
            src="{{ image_desktop | image_url: width: 1200 }}"
            alt="{{ image_desktop.alt | escape }}"
            loading="lazy"
          >
        {%- endif -%}
      </div>

      {%- comment -%} Form column {%- endcomment -%}
      <div class="reset-page__form-col">
        <h1 class="reset-page__title">Reset Password</h1>

        {% form 'reset_customer_password' %}
          <div class="reset-page__fields">
            <div class="reset-page__field reset-page__field--password">
              <input type="password" id="ResetPassword" name="customer[password]" placeholder="New Password" required class="reset-page__input">
              <button type="button" class="reset-page__toggle-pw" data-toggle-password aria-label="Toggle password visibility">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <line x1="1" y1="1" x2="23" y2="23" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
            <div class="reset-page__field reset-page__field--password">
              <input type="password" id="ResetPasswordConfirm" name="customer[password_confirmation]" placeholder="Confirm Password" required class="reset-page__input">
              <button type="button" class="reset-page__toggle-pw" data-toggle-password aria-label="Toggle password visibility">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <line x1="1" y1="1" x2="23" y2="23" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
          </div>

          <button type="submit" class="btn btn--primary reset-page__submit">Reset Password</button>
        {% endform %}

        <div class="reset-page__login-row">
          <span>Remember Your Password?</span>
          <a href="{{ routes.account_login_url }}" class="reset-page__login-link">Log In</a>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('[data-toggle-password]');
    if (!btn) return;
    var input = btn.parentElement.querySelector('input');
    input.type = input.type === 'password' ? 'text' : 'password';
  });
</script>

{% stylesheet %}
  .reset-page { padding: 40px 0; }

  .reset-page__container {
    --bs-gutter-x: 1.5rem;
    width: 100%;
    padding-right: calc(var(--bs-gutter-x) * 0.5);
    padding-left: calc(var(--bs-gutter-x) * 0.5);
    margin-right: auto;
    margin-left: auto;
  }
  @media (min-width: 576px) { .reset-page__container { max-width: 540px; } }
  @media (min-width: 768px) { .reset-page__container { max-width: 720px; } }
  @media (min-width: 992px) { .reset-page__container { max-width: 960px; } }
  @media (min-width: 1200px) { .reset-page__container { max-width: 1140px; } }
  @media (min-width: 1400px) { .reset-page__container { max-width: 1320px; } }

  .reset-page__layout { display: flex; flex-direction: column; gap: 40px; }
  @media (min-width: 768px) { .reset-page__layout { flex-direction: row; align-items: center; gap: 60px; } }

  .reset-page__image-col { width: 100%; }
  @media (min-width: 768px) { .reset-page__image-col { width: 50%; flex-shrink: 0; } }

  .reset-page__image { width: 100%; height: auto; object-fit: cover; border-radius: 6px; display: block; }
  .reset-page__image--mobile { display: block; }
  .reset-page__image--desktop { display: none; }
  @media (min-width: 768px) {
    .reset-page__image--mobile { display: none; }
    .reset-page__image--desktop { display: block; }
  }

  .reset-page__form-col { width: 100%; max-width: 440px; margin: 0 auto; }
  @media (min-width: 768px) { .reset-page__form-col { flex: 1; max-width: none; } }

  .reset-page__title { font-family: 'Outfit', sans-serif; font-size: 28px; font-weight: 700; color: #313d65; text-align: center; margin: 0 0 24px; }
  @media (min-width: 768px) { .reset-page__title { font-size: 32px; margin-bottom: 32px; } }

  .reset-page__fields { display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px; }

  .reset-page__input { width: 100%; height: 40px; padding: 0 16px; border: 1px solid var(--color-brand); background: none; font-family: 'Outfit', sans-serif; font-size: 14px; font-weight: 400; color: var(--color-black); outline: none; text-transform: capitalize; }
  .reset-page__input::placeholder { color: var(--color-text-secondary); text-transform: capitalize; }
  .reset-page__input:focus { border-color: var(--color-brand); }

  .reset-page__field--password { position: relative; }
  .reset-page__field--password .reset-page__input { padding-right: 44px; }

  .reset-page__toggle-pw { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; padding: 0; cursor: pointer; color: var(--color-text-secondary); display: flex; }
  .reset-page__toggle-pw:hover { color: var(--color-black); }

  .reset-page__submit { width: 100%; }

  .reset-page__login-row { display: flex; align-items: center; justify-content: center; gap: 4px; margin-top: 16px; font-family: 'Outfit', sans-serif; font-size: 16px; font-weight: 400; color: var(--color-black); text-transform: capitalize; }
  .reset-page__login-link { font-family: 'Outfit', sans-serif; font-size: 16px; font-weight: 400; color: #313d65; text-decoration: none; text-transform: capitalize; }
  .reset-page__login-link:hover { text-decoration: underline; }
{% endstylesheet %}

{% schema %}
{
  "name": "Customer reset password",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop image"
    }
  ]
}
{% endschema %}
